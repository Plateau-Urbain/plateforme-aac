{
    "type": "project",
    "license": "AGPL-3.0-only",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/annotations": "^2.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.7",
        "doctrine/migrations": "^3.9",
        "doctrine/orm": "^2.19",
        "gedmo/doctrine-extensions": "^3.22",
        "gregwar/captcha-bundle": "^2.2",
        "knplabs/knp-paginator-bundle": "^6.10",
        "sonata-project/admin-bundle": "^4.42",
        "sonata-project/doctrine-orm-admin-bundle": "^4.21",
        "sonata-project/exporter": "^3.4",
        "symfony/brevo-mailer": "6.4.*",
        "symfony/console": "6.4.*",
        "symfony/dotenv": "6.4.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "6.4.*",
        "symfony/http-client": "6.4.*",
        "symfony/mailer": "6.4.*",
        "symfony/runtime": "6.4.*",
        "symfony/security-bundle": "6.4.*",
        "symfony/yaml": "6.4.*",
        "twig/extra-bundle": "^3.24",
        "twig/intl-extra": "^3.26",
        "vich/uploader-bundle": "^2.9"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR% --symlink --relative": "symfony-cmd",
            "python3 scripts/rebuild_bundle_app_assets.py": "script"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*"
        }
    },
    "require-dev": {
        "phpstan/extension-installer": "*",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-doctrine": "*",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.4",
        "symfony/browser-kit": "6.4.*",
        "symfony/css-selector": "6.4.*"
    }
}
