{% extends '@SonataAdmin/standard_layout.html.twig' %}

{% block title %}Statistiques — Porteurs de projet{% endblock %}

{% block content %}
<div class="row">
  <div class="col-md-12">

    {# Fil d'Ariane #}
    <ol class="breadcrumb">
      <li><a href="{{ admin.generateUrl('list') }}"><i class="fa fa-list"></i> Porteurs de projet</a></li>
      <li class="active"><i class="fa fa-bar-chart"></i> Statistiques globales</li>
    </ol>

    {# Filtre par année #}
    <div class="row" style="margin-bottom:16px;">
      <div class="col-md-12">
        <form method="get" class="form-inline" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <label style="font-weight:600;margin:0;"><i class="fa fa-calendar"></i> Période d'inscription :</label>
          <select name="year" class="form-control" onchange="this.form.submit()" style="width:auto;">
            <option value="all" {% if selectedYear == 'all' %}selected{% endif %}>Toutes les années</option>
            {% for yr in availableYears %}
              <option value="{{ yr }}" {% if selectedYear == yr %}selected{% endif %}>{{ yr }}</option>
            {% endfor %}
          </select>
          {% if selectedYear != 'all' %}
            <a href="{{ admin.generateUrl('statistics') }}" class="btn btn-default btn-sm">
              <i class="fa fa-times"></i> Réinitialiser
            </a>
          {% endif %}
          <span class="text-muted" style="font-size:13px;">
            {% if selectedYear != 'all' %}
              Affichage : <strong>{{ selectedYear }}</strong>
            {% else %}
              Affichage : <strong>toutes les années</strong>
            {% endif %}
          </span>
        </form>
      </div>
    </div>

    {# Totaux #}
    <div class="row" style="margin-bottom:20px;">
      <div class="col-sm-4">
        <div class="info-box">
          <span class="info-box-icon bg-aqua"><i class="fa fa-users"></i></span>
          <div class="info-box-content">
            <span class="info-box-text">Total porteurs de projet</span>
            <span class="info-box-number">{{ totalUsers }}</span>
          </div>
        </div>
      </div>
    </div>

    {# Ligne 1 : Département #}
    <div class="row">
      <div class="col-md-12">
        <div class="box box-primary">
          <div class="box-header with-border">
            <h3 class="box-title"><i class="fa fa-map-marker"></i> Répartition par département de la structure</h3>
          </div>
          <div class="box-body" style="max-height: 350px; overflow-y: auto;">
            <div id="zipcodeChart"></div>
          </div>
        </div>
      </div>
    </div>

    {# Ligne 2 : Type de projet + Statut juridique #}
    <div class="row">
      <div class="col-md-6">
        <div class="box box-info">
          <div class="box-header with-border">
            <h3 class="box-title"><i class="fa fa-folder-open-o"></i> Porteurs de projet par type de projet</h3>
          </div>
          <div class="box-body">
            <div id="usageChart"></div>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="box box-info">
          <div class="box-header with-border">
            <h3 class="box-title"><i class="fa fa-building"></i> Porteurs de projet par statut juridique</h3>
          </div>
          <div class="box-body">
            <div id="companyStatusChart"></div>
          </div>
        </div>
      </div>
    </div>

    {# Ligne 3 : Timeline #}
    <div class="row">
      <div class="col-md-12">
        <div class="box box-success">
          <div class="box-header with-border">
            <h3 class="box-title"><i class="fa fa-line-chart"></i> Inscriptions par jour</h3>
          </div>
          <div class="box-body">
            <div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">
              <div id="timelineChartContainer" style="position:relative;height:200px;min-width:600px;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  .horizontal-bar-item { margin-bottom: 10px; }
  .bar-label { font-size: 13px; margin-bottom: 3px; color: #333; }
  .bar-container { display: flex; align-items: center; gap: 8px; }
  .simple-bar-bg { position: relative; flex: 1; height: 22px; background: #f0f0f0; border-radius: 3px; overflow: visible; }
  .simple-bar-fill { height: 100%; border-radius: 3px; transition: width .4s; }
  .simple-bar-value { position: absolute; top: 50%; transform: translateY(-50%); font-size: 12px; font-weight: bold; color: #333; white-space: nowrap; }
  .bar-total-label { font-size: 12px; color: #555; white-space: nowrap; }
</style>

<script>
$(document).ready(function() {

    var colors = ['#4e73df','#1cc88a','#36b9cc','#f6c23e','#e74a3b','#858796','#5a5c69','#6f42c1'];

    // ======================================================
    // GRAPHIQUE 1 : Répartition par département
    // ======================================================
    var deptNames = {
        '01': 'Ain (01)', '02': 'Aisne (02)', '03': 'Allier (03)', '04': 'Alpes-de-Haute-Provence (04)', '05': 'Hautes-Alpes (05)',
        '06': 'Alpes-Maritimes (06)', '07': 'Ardèche (07)', '08': 'Ardennes (08)', '09': 'Ariège (09)', '10': 'Aube (10)',
        '11': 'Aude (11)', '12': 'Aveyron (12)', '13': 'Bouches-du-Rhône (13)', '14': 'Calvados (14)', '15': 'Cantal (15)',
        '16': 'Charente (16)', '17': 'Charente-Maritime (17)', '18': 'Cher (18)', '19': 'Corrèze (19)', '2A': 'Corse-du-Sud (2A)',
        '2B': 'Haute-Corse (2B)', '21': 'Côte-d\'Or (21)', '22': 'Côtes-d\'Armor (22)', '23': 'Creuse (23)', '24': 'Dordogne (24)',
        '25': 'Doubs (25)', '26': 'Drôme (26)', '27': 'Eure (27)', '28': 'Eure-et-Loir (28)', '29': 'Finistère (29)',
        '30': 'Gard (30)', '31': 'Haute-Garonne (31)', '32': 'Gers (32)', '33': 'Gironde (33)', '34': 'Hérault (34)',
        '35': 'Ille-et-Vilaine (35)', '36': 'Indre (36)', '37': 'Indre-et-Loire (37)', '38': 'Isère (38)', '39': 'Jura (39)',
        '40': 'Landes (40)', '41': 'Loir-et-Cher (41)', '42': 'Loire (42)', '43': 'Haute-Loire (43)', '44': 'Loire-Atlantique (44)',
        '45': 'Loiret (45)', '46': 'Lot (46)', '47': 'Lot-et-Garonne (47)', '48': 'Lozère (48)', '49': 'Maine-et-Loire (49)',
        '50': 'Manche (50)', '51': 'Marne (51)', '52': 'Haute-Marne (52)', '53': 'Mayenne (53)', '54': 'Meurthe-et-Moselle (54)',
        '55': 'Meuse (55)', '56': 'Morbihan (56)', '57': 'Moselle (57)', '58': 'Nièvre (58)', '59': 'Nord (59)',
        '60': 'Oise (60)', '61': 'Orne (61)', '62': 'Pas-de-Calais (62)', '63': 'Puy-de-Dôme (63)', '64': 'Pyrénées-Atlantiques (64)',
        '65': 'Hautes-Pyrénées (65)', '66': 'Pyrénées-Orientales (66)', '67': 'Bas-Rhin (67)', '68': 'Haut-Rhin (68)',
        '69': 'Rhône (69)', '70': 'Haute-Saône (70)', '71': 'Saône-et-Loire (71)', '72': 'Sarthe (72)', '73': 'Savoie (73)',
        '74': 'Haute-Savoie (74)', '75': 'Paris (75)', '76': 'Seine-Maritime (76)', '77': 'Seine-et-Marne (77)', '78': 'Yvelines (78)',
        '79': 'Deux-Sèvres (79)', '80': 'Somme (80)', '81': 'Tarn (81)', '82': 'Tarn-et-Garonne (82)', '83': 'Var (83)',
        '84': 'Vaucluse (84)', '85': 'Vendée (85)', '86': 'Vienne (86)', '87': 'Haute-Vienne (87)', '88': 'Vosges (88)',
        '89': 'Yonne (89)', '90': 'Territoire de Belfort (90)', '91': 'Essonne (91)', '92': 'Hauts-de-Seine (92)',
        '93': 'Seine-Saint-Denis (93)', '94': 'Val-de-Marne (94)', '95': 'Val-d\'Oise (95)',
        '971': 'Guadeloupe (971)', '972': 'Martinique (972)', '973': 'Guyane (973)', '974': 'La Réunion (974)', '976': 'Mayotte (976)'
    };

    var rawZipData = [
        {% for key, row in zipcodeRows %}
        {
            dept: {{ row.label|json_encode|raw }},
            value: {{ row.total }},
            color: colors[{{ key }} % colors.length]
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ];

    var zipData = rawZipData.map(function(item) {
        var label = deptNames[item.dept] || (item.dept === 'Non renseigné' ? 'Non renseigné' : 'Département ' + item.dept);
        return {
            label: label,
            value: item.value,
            color: item.color
        };
    });

    var maxZip = Math.max.apply(Math, zipData.map(function(d) { return d.value; }));
    if (maxZip === 0 || isNaN(maxZip)) maxZip = 1;

    var zipContainer = $('#zipcodeChart');
    zipContainer.empty();

    if (zipData.length === 0) {
        zipContainer.append('<div class="text-center text-muted" style="padding:20px 0;">Aucune donnée de département</div>');
    } else {
        zipData.forEach(function(item) {
            var pct = (item.value / maxZip) * 100;
            var valuePos = pct < 30 ? 'left:' + (pct + 2) + '%;' : 'left:' + pct + '%;transform:translateX(-100%) translateY(-50%);';
            if (pct < 30) valuePos += 'transform:translateY(-50%);';

            var html = '<div class="horizontal-bar-item">' +
                '<div class="bar-label" title="' + item.label + '">' + item.label + '</div>' +
                '<div class="bar-container">' +
                '<div class="simple-bar-bg"><div class="simple-bar-fill" style="background:' + item.color + ';width:' + pct + '%;"></div>' +
                '<span class="simple-bar-value" style="' + valuePos + 'top:50%;">' + item.value + ' porteur(s)</span>' +
                '</div></div></div>';
            zipContainer.append(html);
        });
    }

    // ======================================================
    // GRAPHIQUE 2 : Par type de projet (UseType)
    // ======================================================
    var usageColors = ['#5B9BD5','#ED7D31','#A5A5A5','#FFC000','#4472C4','#70AD47','#264478','#9B59B6'];
    var usageData = [
        {% for key, row in useTypeRows %}
        {
            label: {{ (row.name ~ (row.isActive ? '' : ' (archivé)'))|json_encode|raw }},
            value: {{ row.total }},
            color: usageColors[{{ key }} % 8]
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ];

    var maxUsage = Math.max.apply(Math, usageData.map(function(d) { return d.value; }));
    if (maxUsage === 0) maxUsage = 1;

    var usageContainer = $('#usageChart');
    usageContainer.empty();

    if (usageData.length === 0) {
        usageContainer.html('<p class="text-muted">Aucune donnée disponible.</p>');
    } else {
        usageData.forEach(function(item) {
            if (item.value === 0) return;
            var pct = (item.value / maxUsage) * 100;
            var valuePos = pct < 30 ? 'left:' + (pct + 2) + '%;' : 'left:' + pct + '%;transform:translateX(-100%) translateY(-50%);';
            if (pct < 30) valuePos += 'transform:translateY(-50%);';
            var html = '<div class="horizontal-bar-item">' +
                '<div class="bar-label">' + item.label + '</div>' +
                '<div class="bar-container">' +
                '<div class="simple-bar-bg"><div class="simple-bar-fill" style="background:' + item.color + ';width:' + pct + '%;"></div>' +
                '<span class="simple-bar-value" style="' + valuePos + 'top:50%;">' + item.value + ' porteur(s)</span>' +
                '</div></div></div>';
            usageContainer.append(html);
        });
    }

    // ======================================================
    // GRAPHIQUE 3 : Par statut juridique (User companyStatus)
    // ======================================================
    var csColors = ['#4472C4','#ED7D31','#A5A5A5','#FFC000'];
    var companyStatusData = [
        {% for key, row in companyStatusRows %}
        { label: {{ row.companyStatus|json_encode|raw }}, value: {{ row.total }}, color: csColors[{{ key }} % 4] }{% if not loop.last %},{% endif %}
        {% endfor %}
    ];

    var maxCs = Math.max.apply(Math, companyStatusData.map(function(d) { return d.value; }));
    if (maxCs === 0) maxCs = 1;

    var csContainer = $('#companyStatusChart');
    csContainer.empty();

    if (companyStatusData.length === 0) {
        csContainer.html('<p class="text-muted">Aucun statut juridique renseigné.</p>');
    } else {
        companyStatusData.forEach(function(item) {
            var pct = (item.value / maxCs) * 100;
            var valuePos = pct < 30 ? 'left:' + (pct + 2) + '%;' : 'left:' + pct + '%;transform:translateX(-100%) translateY(-50%);';
            if (pct < 30) valuePos += 'transform:translateY(-50%);';
            var html = '<div class="horizontal-bar-item">' +
                '<div class="bar-label">' + item.label + '</div>' +
                '<div class="bar-container">' +
                '<div class="simple-bar-bg"><div class="simple-bar-fill" style="background:' + item.color + ';width:' + pct + '%;"></div>' +
                '<span class="simple-bar-value" style="' + valuePos + 'top:50%;">' + item.value + ' porteur(s)</span>' +
                '</div></div></div>';
            csContainer.append(html);
        });
    }

    // ======================================================
    // GRAPHIQUE 4 : Timeline — inscriptions par jour
    // ======================================================
    var timelineData = {
        {% for row in timelineRows %}
        {{ row.day|json_encode|raw }}: {{ row.total }}{% if not loop.last %},{% endif %}
        {% endfor %}
    };

    var tlContainer = $('#timelineChartContainer');
    tlContainer.empty();

    var days = Object.keys(timelineData).sort();
    if (days.length === 0) {
        tlContainer.html('<p class="text-muted">Aucune donnée de timeline.</p>');
    } else {
        var maxTl = Math.max.apply(Math, days.map(function(d) { return timelineData[d]; }));
        if (maxTl === 0) maxTl = 1;

        var minW = tlContainer.width() || 700;
        var svgW = Math.max(minW, days.length * 12);
        tlContainer.css('width', svgW + 'px');
        var svgH = 180;
        var padL = 35, padR = 15, padT = 10, padB = 30;
        var plotW = svgW - padL - padR;
        var plotH = svgH - padT - padB;
        var step = plotW / Math.max(days.length - 1, 1);

        var points = days.map(function(p, i) {
            return { x: padL + i * step, y: padT + plotH - (timelineData[p] / maxTl) * plotH, v: timelineData[p], d: p };
        });

        var polyline = points.map(function(p) { return p.x + ',' + p.y; }).join(' ');
        var areaPath = 'M ' + points[0].x + ' ' + (padT + plotH) +
            ' L ' + points.map(function(p) { return p.x + ' ' + p.y; }).join(' L ') +
            ' L ' + points[points.length - 1].x + ' ' + (padT + plotH) + ' Z';

        var circles = points.map(function(p) {
            return '<circle cx="' + p.x + '" cy="' + p.y + '" r="5" fill="#1cc88a" stroke="#fff" stroke-width="2"' +
                ' data-date="' + p.d + '" data-count="' + p.v + '" class="tl-dot" style="cursor:pointer;"></circle>';
        }).join('');

        var xLabels = '';
        var step2 = Math.max(1, Math.floor(days.length / 8));
        points.forEach(function(p, i) {
            if (i % step2 === 0 || i === days.length - 1) {
                xLabels += '<text x="' + p.x + '" y="' + (padT + plotH + 18) + '" text-anchor="middle" font-size="10" fill="#666">' + p.d.substring(5) + '</text>';
            }
        });

        var yLabel = '<text x="' + (padL - 5) + '" y="' + (padT + plotH / 2) + '" text-anchor="end" font-size="10" fill="#666">' + maxTl + '</text>' +
            '<text x="' + (padL - 5) + '" y="' + (padT + plotH) + '" text-anchor="end" font-size="10" fill="#666">0</text>';

        var svg = '<svg width="100%" height="' + svgH + '" viewBox="0 0 ' + svgW + ' ' + svgH + '" style="overflow:visible;">' +
            '<defs><linearGradient id="tlGrad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#1cc88a" stop-opacity="0.3"/><stop offset="100%" stop-color="#1cc88a" stop-opacity="0"/></linearGradient></defs>' +
            '<path d="' + areaPath + '" fill="url(#tlGrad)"/>' +
            '<polyline points="' + polyline + '" fill="none" stroke="#1cc88a" stroke-width="2"/>' +
            circles + xLabels + yLabel +
            '</svg>';

        tlContainer.html(svg);

        var $tlTooltip = $('<div id="tl-tooltip" style="position:fixed;background:#333;color:#fff;padding:5px 10px;border-radius:4px;font-size:12px;pointer-events:none;display:none;z-index:9999;white-space:nowrap;"></div>').appendTo('body');

        tlContainer.on('mouseenter', '.tl-dot', function(e) {
            var date = $(this).data('date');
            var count = $(this).data('count');
            $tlTooltip.text(date + ' : ' + count + ' inscription(s)').show();
        }).on('mousemove', '.tl-dot', function(e) {
            $tlTooltip.css({ left: e.clientX + 12, top: e.clientY - 28 });
        }).on('mouseleave', '.tl-dot', function() {
            $tlTooltip.hide();
        });
    }

});
</script>
{% endblock %}
