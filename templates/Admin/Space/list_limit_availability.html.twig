{% extends '@SonataAdmin/CRUD/base_list_field.html.twig' %}

{% block field %}
    {% if object.isMultiLocation %}
        <span class="sonata-space-open-badge">Ouvertes</span>
    {% elseif value %}
        {{ value|date('d/m/Y') }}
    {% else %}
        <span class="text-muted">—</span>
    {% endif %}
{% endblock %}
