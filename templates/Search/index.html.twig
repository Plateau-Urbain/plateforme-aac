{% block javascript %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Vérifier si l'élément avec la classe "connectMenured" est présent dans le DOM
      const connectMenured = document.querySelector('.connectMenured');
      if (connectMenured) { // Si .connectMenured est chargé
        // Cacher la section avec la classe "beige"
        const beige = document.querySelector('.beige');
        if (beige) {
          beige.style.display = 'none'; // Cache la section beige
        }

        // Cacher le conteneur avec la classe "separateur"
        const separateur = document.querySelector('.separateur');
        if (separateur) {
          separateur.style.display = 'none'; // Cache le conteneur separateur
        }

        // Cacher le conteneur avec la classe "info-inscription"
        const infoInscription = document.querySelector('.info-inscription');
        if (infoInscription) {
          infoInscription.style.display = 'none'; // Cache le conteneur info-inscription
        }
      }
    });
  </script>
{% endblock %}