{#        <h2 class="section-title animate-from-bottom animation-from-bottom" data-animation-direction="from-bottom" data-animation-delay="50">Les espaces disponibles</h2>#}

        {% if latest|length %}
            {% for space in latest %}
                <div class="item col-xs-12 col-md-6 col-lg-4">
                     <div class="space_item{{ space.isProposedByAdmin ? ' space-card--by-admin' : ' space-card--by-proprio' }}">
                    {% if space.isProposedByAdmin %}
                      <span class="pu-managed-badge"><i class="fa fa-shield"></i> {{ space.managedByLabel }} par Plateau Urbain</span>
                    {% elseif space.owner and space.owner.company %}
                      <span class="pu-owner-badge"><i class="fa fa-building"></i> {{ space.managedByLabel }} par {{ space.owner.company }}</span>
                    {% endif %}
                    <!-- Set width to 4 columns for grid view mode only -->
                    <a href="{{ path('space_show', {'id' : space.id}) }}" >
