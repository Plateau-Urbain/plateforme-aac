                                <span class="availability-text">Durée du projet : {{ space.availability }}</span>
                            </div>
                            {% if isAdmin is defined and isAdmin %}
                                {% if not space.enabled %}
                                    <div class="admin-status-overlay" style="position: absolute; top: 10px; left: 10px; background: rgba(255, 165, 0, 0.9); color: white; padding: 3px 8px; border-radius: 3px; font-size: 10px; font-weight: bold;">
                                        DÉSACTIVÉ
