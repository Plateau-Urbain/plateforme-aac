  <div class="white"> 
        <div class="container"> 
<div class="col-sm-12 ">
 <div class="titre-page-hr">
    <h1>{{ space.name }}</h1>
    <div class="img-aac"><img src="{{ asset('images/groupe_1051.png') }}" alt="Plateau Urbain" /></div>
 </div>
</div>
<div class="row">
  <!-- BEGIN MAIN CONTENT -->
  <div class="col-sm-12">
    <h1 class="property-title">
    {#  {{ space.name }} {% if space.size is not empty %}à partir de {{ space.minSize }}m<sup>2</sup>{% endif %}
       <small>{{ space.city }} ({{ space.zipCode|slice(0,2)}})</small> #}
    </h1>
  </div>
</div>

<div class="row">
  
    <div class="sidebar col-xs-12 col-md-4 sticky">
       <h6><a href="{{ path('search_index') }}" class="red"><span class="sub-arrow"><i class="fa fa-square"></i></span>Tous les appels à candidatures</a></h6>
    <div class="content ">
      <h6>en bref</h6>
      <p class="pu-label">Commune&nbsp;: {{ space.displayCity|default(space.city) }}{% if not space.isMultiLocation and space.displayZipCode|default(space.zipCode) %} ({{ (space.displayZipCode|default(space.zipCode))|slice(0,2) }}){% endif %}</p>
      <p class="pu-label">Type de locaux&nbsp;: {{ space.type }}</p>
       <p class="pu-label">Bailleur&nbsp;: {% if space.owner %}
        {% if space.owner.website %}
          <a href="{{ space.owner.website }}" target="_blank">{{ space.owner.company }}</a>
        {% else %}
          {{ space.owner.company }}
        {% endif %}
      {% else %}
          Sans bailleur
      {% endif %}
      </p>

    <div class="pu-price-zone ">
    <p class="pu-label">Prix&nbsp;: </sup>
            {% if space.priceText %}
                {{ space.priceText }}
            {% else %}
                À partir de {{ (space.price * 12)|number_format(2, ',', ' ')|replace({',00': ''}) }} € / m<sup>2</sup> / an
                <br />Soit {{ space.price|number_format(2, ',', ' ')|replace({',00': ''}) }} € / m<sup>2</sup> / mois
            {% endif %}
            </p>
    
      {#   <dl class="dl-horizontal">
  
          <dd>
            <span class="pu-title"><strong>{{ space.parcels | length }}</strong> espaces</span>
            De {{ space.minSpace }} m<sup>2</sup> à {{ space.maxSpace }} m<sup>2</sup>
            <a href="#parcels">Voir la répartition des espaces</a>
          </dd>
        </dl> #} 
            <p class="pu-label">Durée du projet&nbsp;: {{ space.availability }}</p>
            {% if space.nbSpaces or space.minSpace or space.maxSpace %}
            <p class="pu-label">
              Surfaces&nbsp;:
              {% if space.nbSpaces %}{{ space.nbSpaces }} espace(s){% endif %}
              {% if space.minSpace or space.maxSpace %}
                de {{ space.minSpace|default('?') }} m<sup>2</sup> à {{ space.maxSpace|default('?') }} m<sup>2</sup>
              {% endif %}
            </p>
            {% endif %}
     
    </div>
</div>
  

    <div class="pu-apply-zone">
      {% if space.isMultiLocation %}
