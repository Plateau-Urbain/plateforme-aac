{% extends "base.html.twig" %}

{% block title %}{{ space.name }} | Plateau Urbain{% endblock %}

{% block meta_description %}
  {% if space.city is defined and space.city %}
    Appel à candidatures – {{ space.name }} ({{ space.city }}).
  {% else %}
    Appel à candidatures – {{ space.name }}.
  {% endif %}
{% endblock %}

{% block og_image %}
  {% if space.pics is defined and space.pics|length %}
    {{ app.request.schemeAndHttpHost ~ vich_uploader_asset(space.pics|first, 'file') }}
  {% else %}
    {{ parent() }}
  {% endif %}
{% endblock %}

{# {% block breadcrumb_items %}
  <li><a href="{{ path('search_index') }}">Recherche</a></li>
  <li><span>Fiche espace</span></li>
{% endblock %}
 #}
{% block body %}

