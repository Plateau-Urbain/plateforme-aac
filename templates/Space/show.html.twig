{% block stylesheets %}
    {{ parent() }}
    <style>
        .auth-buttons {
            display: flex;
            flex-direction: column;
            gap: 10px;
            align-items: center;
        }
        .auth-buttons .btn {
            width: 100%;
            max-width: 200px;
        }

        /* --- Galerie photos (Bootstrap Carousel + vignettes) --- */
        .pu-gallery-wrapper {
            margin-bottom: 20px;
        }

        /* Image principale */
        #spaceCarousel .item img {
            width: 100%;
            height: 420px;
            object-fit: cover;
            object-position: center;
            display: block;
        }

        /* Flèches de navigation */
        #spaceCarousel .carousel-control {
            background-image: none;
            width: 40px;
            opacity: 1;
        }
        #spaceCarousel .carousel-control .glyphicon {
            color: #fff;
            font-size: 22px;
            text-shadow: 0 1px 4px rgba(0,0,0,0.6);
            top: 50%;
            transform: translateY(-50%);
            margin: 0;
        }

        /* Indicateurs (bullets) */
        #spaceCarousel .carousel-indicators {
            bottom: 8px;
        }
        #spaceCarousel .carousel-indicators li {
            background-color: rgba(255,255,255,0.55);
            border: 1px solid rgba(255,255,255,0.8);
            width: 10px;
            height: 10px;
        }
        #spaceCarousel .carousel-indicators .active {
            background-color: #fff;
            width: 12px;
            height: 12px;
        }

        /* Vignettes cliquables */
        .pu-gallery-thumbs {
            display: flex;
            gap: 6px;
            margin-top: 6px;
            flex-wrap: wrap;
        }
        .pu-gallery-thumb {
            flex: 0 0 auto;
            width: 80px;
            height: 56px;
            cursor: pointer;
            border: 2px solid transparent;
            border-radius: 3px;
            overflow: hidden;
            opacity: 0.65;
            transition: opacity 0.2s, border-color 0.2s;
        }
        .pu-gallery-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }
        .pu-gallery-thumb:hover {
            opacity: 0.9;
        }
        .pu-gallery-thumb.active {
            border-color: #c0392b;
            opacity: 1;
        }

        @media (max-width: 768px) {
            #spaceCarousel .item img { height: 220px; }
            .pu-gallery-thumb { width: 60px; height: 42px; }
        }

        .aac-location-suspended {
            opacity: 0.85;
        }
        .aac-map-hint {
            margin-bottom: 12px;
            font-size: 14px;
        }
        #aac-locations-map {
            height: 420px;
            margin-bottom: 0;
            border: 1px solid #ddd;
            border-radius: 4px;
            background: #f5f5f5;
        }
        #aac-locations-map .leaflet-container {
            height: 100%;
            width: 100%;
            border-radius: 4px;
        }
        #aac-locations-map .leaflet-popup-content {
            margin: 14px 18px;
            line-height: 1.4;
            min-width: 200px;
            max-width: 320px;
        }
        #aac-locations-map .aac-map-popup-name {
            display: block;
            font-size: 20px;
            font-weight: 600;
            color: #1C244B;
            margin-bottom: 4px;
        }
        #aac-locations-map .aac-map-popup-address {
            display: block;
            font-size: 14px;
            color: #666;
        }
        #aac-locations-map .aac-map-popup-description {
            margin-top: 10px;
            font-size: 14px;
            color: #333;
        }
        #aac-locations-map .aac-map-popup-badge {
            display: inline-block;
            margin-top: 10px;
            padding: 3px 8px;
            font-size: 12px;
            font-weight: 600;
            color: #555;
            background: #eee;
            border-radius: 3px;
        }
        #aac-locations-map .aac-map-popup-suspended {
            margin-top: 12px;
            padding: 8px 10px;
            font-size: 13px;
            color: #8a6d3b;
            background: #fcf8e3;
            border: 1px solid #faebcc;
            border-radius: 4px;
        }
    </style>
    {% if space.isMultiLocation and space.locations|length > 0 %}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    {% endif %}
{% endblock %}

{% block javascript %}
    {{ parent() }}
    {% if space.isMultiLocation and space.locations|length > 0 %}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    {% endif %}
    <script>
        $(document).ready(function () {
            /* Sync vignettes → carousel */
            $('.pu-gallery-thumb').on('click', function () {
                var idx = $(this).data('slide-to');
                $('#spaceCarousel').carousel(idx);
            });

            /* Sync carousel → vignettes */
            $('#spaceCarousel').on('slid.bs.carousel', function () {
                var active = $(this).find('.item.active');
                var idx = active.index();
                $('.pu-gallery-thumb').removeClass('active').eq(idx).addClass('active');
            });

            {% if space.isMultiLocation and space.locations|length > 0 %}
            initAacLocationsMap();
            {% endif %}
        });

        {% if space.isMultiLocation and space.locations|length > 0 %}
        function initAacLocationsMap() {
            var mapEl = document.getElementById('aac-locations-map');
            if (typeof L === 'undefined' || !mapEl) {
                return;
            }

            var locations = [
                {% for location in space.locations %}
                {
                    name: {{ location.name|json_encode|raw }},
                    lat: {{ location.latitude ?? 'null' }},
                    lng: {{ location.longitude ?? 'null' }},
                    address: {{ location.address|default('')|json_encode|raw }},
                    zipCode: {{ location.zipCode|default('')|json_encode|raw }},
                    city: {{ location.city|default('')|json_encode|raw }},
                    fullAddress: {{ location.fullAddress|json_encode|raw }},
                    description: {{ location.description|default('')|json_encode|raw }},
                    isErp: {{ location.isErp ? 'true' : 'false' }},
                    suspended: {{ location.suspended ? 'true' : 'false' }},
                    suspensionMessage: {{ location.suspensionMessage|default('')|json_encode|raw }}
                }{% if not loop.last %},{% endif %}
                {% endfor %}
            ];

            var map = L.map(mapEl).setView([46.6, 2.4], 6);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            var bounds = [];
            var pending = 0;

            function escapeHtml(text) {
                var div = document.createElement('div');
                div.textContent = text || 'Site';
                return div.innerHTML;
            }

            function formatMultiline(text) {
                return escapeHtml(text).replace(/\n/g, '<br>');
            }

            function buildPopupContent(loc) {
                var html = '<span class="aac-map-popup-name">' + escapeHtml(loc.name) + '</span>';

                if (loc.fullAddress) {
                    html += '<span class="aac-map-popup-address">' + escapeHtml(loc.fullAddress) + '</span>';
                }

                if (loc.description) {
                    html += '<div class="aac-map-popup-description">' + formatMultiline(loc.description) + '</div>';
                }

                if (loc.isErp) {
                    html += '<span class="aac-map-popup-badge">ERP</span>';
                }

                if (loc.suspended && loc.suspensionMessage) {
                    html += '<div class="aac-map-popup-suspended"><i class="fa fa-pause-circle"></i> ' + formatMultiline(loc.suspensionMessage) + '</div>';
                }

                return html;
            }

            function addMarker(loc, lat, lng) {
                var marker = L.marker([lat, lng], {
                    opacity: loc.suspended ? 0.5 : 1
                }).addTo(map);
                marker.bindPopup(buildPopupContent(loc), { maxWidth: 340 });
                bounds.push([lat, lng]);
            }

            function finalizeMap() {
                if (bounds.length === 1) {
                    map.setView(bounds[0], 14);
                } else if (bounds.length > 1) {
                    map.fitBounds(bounds, { padding: [30, 30] });
                }
                setTimeout(function () { map.invalidateSize(); }, 200);
            }

            locations.forEach(function (loc) {
                if (loc.lat !== null && loc.lng !== null && !isNaN(loc.lat) && !isNaN(loc.lng)) {
                    addMarker(loc, loc.lat, loc.lng);
                    return;
                }

                if (!loc.city && !loc.zipCode && !loc.address) {
                    return;
                }

                pending++;
                $.ajax({
                    url: '{{ path('api_geocode') }}',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        address: loc.address,
                        zipCode: loc.zipCode,
                        city: loc.city
                    })
                }).done(function (data) {
                    if (data.lat && data.lng) {
                        addMarker(loc, data.lat, data.lng);
                    }
                }).always(function () {
                    pending--;
                    if (pending === 0) {
                        finalizeMap();
                    }
                });
            });

            if (pending === 0) {
                finalizeMap();
            }
        }
        {% endif %}
    </script>
{% endblock %}
