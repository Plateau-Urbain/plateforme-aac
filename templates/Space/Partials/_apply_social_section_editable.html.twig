{# Section Réseaux sociaux — formulaire de candidature (éditable) #}
<div class="row" >
    <div class="col-sm-6 form-group{% if not form.projectHolder.facebookUrl.vars.valid %} has-error{% endif %}">
        <div class="input-group social-group">
            <span class="input-group-addon"><i class="fa-brands fa-facebook-f fa-lg"></i></span>
            {{ form_widget(form.projectHolder.facebookUrl) }}
            {{ form_errors(form.projectHolder.facebookUrl) }}
        </div>
    </div>

    <div class="col-sm-6 form-group{% if not form.projectHolder.twitterUrl.vars.valid %} has-error{% endif %}">
        <div class="input-group social-group">
            <span class="input-group-addon" aria-label="X (anciennement Twitter)">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1.33em" height="1.33em" fill="currentColor" aria-hidden="true" focusable="false" role="img">
                    <path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/>
                </svg>
            </span>
            {{ form_widget(form.projectHolder.twitterUrl) }}
            {{ form_errors(form.projectHolder.twitterUrl) }}
        </div>
    </div>
</div>

