<div class="row" >
    <div class="col-sm-6 form-group{% if not form.projectHolder.googleUrl.vars.valid %} has-error{% endif %}">
        <div class="input-group social-group">
            <span class="input-group-addon" aria-label="Bluesky">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 530" width="1.33em" height="1.33em" fill="currentColor" aria-hidden="true" focusable="false" role="img">
                    <path d="m135.72 44.03c66.5 49.92 138.02 151.14 164.28 205.46 26.26-54.32 97.78-155.54 164.28-205.46 47.98-36.021 125.72-63.892 125.72 24.795 0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3797-3.6904-10.832-3.7077-7.8964-0.0174-2.9357-1.1937 0.51669-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4491-163.25-81.433-5.9562-21.282-16.111-152.36-16.111-170.07 0-88.687 77.742-60.816 125.72-24.795z"/>
                </svg>
            </span>
            {{ form_widget(form.projectHolder.googleUrl) }}
            {{ form_errors(form.projectHolder.googleUrl) }}
        </div>
    </div>

    <div class="col-sm-6 form-group{% if not form.projectHolder.otherUrl.vars.valid %} has-error{% endif %}">
