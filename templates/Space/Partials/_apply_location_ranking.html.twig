<div class="row">
    <div class="col-sm-12 form-group location-preferences-block{% if not form.locationPreferences.vars.valid %} has-error{% endif %}">
        <p class="location-preferences-help">
            Classez les sites proposés par ordre de préférence (1 = votre choix principal).
            Utilisez les flèches pour modifier l'ordre.
        </p>

        <ol id="location-preferences-list" class="location-preferences-list">
            {% for preferenceForm in form.locationPreferences %}
                {% set location = preferenceForm.vars.data.location %}
                <li class="location-preference-item">
                    <span class="js-preference-rank-label location-preference-rank">{{ preferenceForm.vars.data.rank }}</span>
                    <div class="location-preference-info">
                        <strong>{{ location.name }}</strong>
                        {% if location.city %}
                            <span class="location-preference-city">{{ location.city }}{% if location.zipCode %} ({{ location.zipCode|slice(0, 2) }}){% endif %}</span>
                        {% endif %}
                        {% if location.description %}
                            <p class="location-preference-description">{{ location.description }}</p>
                        {% endif %}
                    </div>
                    <div class="location-preference-actions">
                        <button type="button" class="btn btn-default btn-sm js-move-preference-up" title="Monter">
                            <i class="fa fa-chevron-up"></i>
                        </button>
                        <button type="button" class="btn btn-default btn-sm js-move-preference-down" title="Descendre">
                            <i class="fa fa-chevron-down"></i>
                        </button>
                    </div>
                    <span class="location-preference-hidden-fields">
                        {{ form_widget(preferenceForm.rank) }}
                        {{ form_widget(preferenceForm.location, { attr: { class: 'js-preference-location-input' } }) }}
                    </span>
                </li>
            {% endfor %}
        </ol>

        {{ form_errors(form.locationPreferences) }}
    </div>
</div>
