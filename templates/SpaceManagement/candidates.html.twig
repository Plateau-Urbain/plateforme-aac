      </h4> #}

      <div class="">
        <h3 class="page-title">Liste des candidat•es</h3>
        <div style="margin-top: 10px; margin-bottom: 15px;">
          <p style="margin-bottom: 5px;">
            <strong>{{ space.nbValidApplication }}</strong> candidature(s) au total
            
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 15px; margin-top: 8px;">
            <span class="label-status awaiting" style="display: inline-block; padding: 5px 10px; border-radius: 4px;">
              <i class="fa fa-hourglass-half"></i>&nbsp;
              {{ space.nbApplication(constant('App\\Entity\\Application::WAIT_STATUS')) }} en attente
            </span>
            <span class="label-status rejected" style="display: inline-block; padding: 5px 10px; border-radius: 4px;">
              <i class="fa fa-times"></i>&nbsp;
              {{ space.nbApplication(constant('App\\Entity\\Application::REJECT_STATUS')) }} refusées
            </span>
            <span class="label-status accepted" style="display: inline-block; padding: 5px 10px; border-radius: 4px;">
              <i class="fa fa-check"></i>&nbsp;
              {{ space.nbApplication(constant('App\\Entity\\Application::ACCEPT_STATUS')) }} acceptées
            </span>
            {% if space.nbApplication(constant('App\\Entity\\Application::UNREAD_STATUS')) > 0 %}
              <span class="label-status" style="display: inline-block; padding: 5px 10px; border-radius: 4px; background-color: #6c757d; color: white;">
                <i class="fa fa-envelope"></i>&nbsp;
                {{ space.nbApplication(constant('App\\Entity\\Application::UNREAD_STATUS')) }} non lues
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div id="management-toolbar">
      <div class="row row-flex-panels">
        <!-- 1. SECTION GESTION / ACTIONS GROUPÉES -->
        <div class="col-panel">
          <div class="ctrl-panel panel-actions" style="height: calc(100% - 20px);">
            <h5><i class="fa fa-cogs"></i> Gestion des candidatures</h5>
            <div style="display: flex; gap: 10px; align-items: flex-start;">
              <div class="form-control-large" style="margin: 0; flex: 1;">
                <select id="groupActionSelect" data-placeholder="Appliquer une action aux sélectionnés...">
                  <option value=""> </option>
                  <option value="accept">Accepter les candidatures</option>
                  <option value="refuse">Refuser les candidatures</option>
                </select>
              </div>
              <div class="btn-appli">
                <a href="#accept_content" class="btn btn-line-19 btn-form" id="groupActionBtn" style="margin-top: 0;">Appliquer</a>
              </div>
            </div>
            <p class="small text-muted" style="margin-top: 10px;">
              <i class="fa fa-info-circle"></i> Sélectionnez les candidat·es via les cases à cocher dans la liste ci-dessous.
            </p>
          </div>
        </div>

        <!-- 2. SECTION FILTRES ET TRI -->
        <div class="col-panel">
          <div class="ctrl-panel panel-filters" style="height: calc(100% - 20px);">
            <h5><i class="fa fa-filter"></i> Filtres et Tri</h5>
            {% form_theme filterForm 'Form/custom_front_fields.html.twig' %}
            {{ form_start(filterForm, { 'attr': { 'data-submit': true } } ) }}
            <div class="row">
              <div class="col-xs-12 col-sm-4" style="margin-bottom: 5px;">
                <label class="small">Statut :</label>
                {{ form_widget(filterForm.status_filter) }}
              </div>
              <div class="col-xs-12 col-sm-5" style="margin-bottom: 5px;">
                <label class="small">Trier par :</label>
                {{ form_widget(filterForm.sort_field) }}
              </div>
              <div class="col-xs-12 col-sm-3" style="margin-bottom: 5px;">
                <label class="small">Ordre :</label>
                {{ form_widget(filterForm.sort_order) }}
              </div>
            </div>
            {{ form_end(filterForm) }}
          </div>
        </div>
      </div>

      <!-- 3. SECTION EXPORT -->
      <div class="ctrl-panel panel-export">
        <h5><i class="fa fa-download"></i> Export des données</h5>
        <div class="btn-toolbar">
          <a href="{{ path('space_manager_select_export_fields', { 'id': space.id }) }}" class="btn btn-success btn-line-16" style="background-color: #4CAF50; border-color: #4CAF50; color: white !important;">
            <i class="fa fa-star"></i>
            Export personnalisé
          </a>
          <a href="{{ path('space_manager_candidatesexport', { 'id': space.id }) }}" class="btn btn-line-16">
            <i class="fa fa-download"></i>
            Export CSV sans tri
          </a>
          <a href="{{ path('space_manager_candidatesexportzip', { 'id': space.id }) }}" class="btn btn-line-16">
            <i class="fa fa-file-archive-o"></i>
            Export complet (avec documents)
          </a>
          <button type="button" class="btn btn-line-16" id="exportSelectedBtn" disabled>
            <i class="fa fa-check-square-o"></i>
            Export sélection (avec documents) (<span id="selectedCount">0</span>)
          </button>
          <a href="javascript:print();" class="btn btn-line-16">
            <i class="fa fa-print"></i>
            Imprimer
          </a>
        </div>
      </div>
    </div>
 
 


  


{# En-tête visible uniquement à l'impression #}
<div class="print-header">
    <h2>{{ space.name }}</h2>
    <p style="font-size: 11pt; color: #333; margin: 5px 0;">
        <strong>{{ space.nbValidApplication }}</strong> candidature(s) au total &nbsp;&mdash;&nbsp;
        <span style="color: #8a6d3b;">{{ space.nbApplication(constant('App\\Entity\\Application::WAIT_STATUS')) }} en attente</span> &nbsp;&mdash;&nbsp;
        <span style="color: #2d6a2d;">{{ space.nbApplication(constant('App\\Entity\\Application::ACCEPT_STATUS')) }} acceptée(s)</span> &nbsp;&mdash;&nbsp;
        <span style="color: #a94442;">{{ space.nbApplication(constant('App\\Entity\\Application::REJECT_STATUS')) }} refusée(s)</span>
    </p>
    <p style="font-size: 10pt; color: #666; margin: 3px 0;">Imprimé le {{ "now"|date("d/m/Y à H:i") }}</p>
</div>

<div class="application-list">
  {% for application in pagination %}
    <div class="item candidate-item" id="application-{{ application.id }}">
      <div class="row row-flex">
        <div class=" col-xs-12 col-md-12 border-box">
          
           <div class="actions" {% if application.category %}data-category="{{ application.category.id }}"{% endif %}>
            <input type="checkbox" class="exportCheck" value="{{ application.id }}" data-status="{{ application.status }}" />
        </div>
        <div class="candidate-argus">
          <div class="cell-content ">
            <div class="application-status">
              {% if application.status == 'unread' or application.status == 'awaiting'  %}
                Statut: <strong class="awaiting">{{ application.statusLabel | upper }}</strong>
              {% elseif application.status == 'accepted'  %}
                Statut: <strong class="accepted">{{ application.statusLabel | upper }}</strong>
              {% elseif application.status == 'rejected'  %}
                Statut: <strong class="rejected">{{ application.statusLabel | upper }}</strong>
              {% endif %}
            </div>
            <div class="application-title">
                <h3>{{ application.name }}</h3>
                PAR <strong>{{ application.projectHolder.company }}</strong>
            </div>

            <dl class="dl-horizontal dl-with-icon">
             {#  <dt><i class="icon small user-brown"></i></dt> #}
              <p class="dd-title"><strong>{{ application.projectHolder.fullName }}</strong></p>
             
              <p><span class="">{{ application.description|length > 250 ? application.description|slice(0, 250) ~ '…' : application.description }}</span></p>
            </dl>
          </div>
      
           <div class="border-candidat">
           <div class="pull-right star">
              <a class="toggle-star" href="{{ path('space_manager_toggle_selected_application', { 'id': application.id, '_token': csrf_token('toggle_selected_' ~ application.id) }) }}">
                {% if application.selected %}
                  <i class="fa-solid fa-star fa-lg"></i>
                {% else %}
                  <i class="fa-regular fa-star fa-lg"></i>
                {% endif %}
              </a>
            </div>
         
          <div class="cell-content-right ">
            <ul class="application-desc">
              <li>Candidature déposée le : <strong>{{ application.created | date('d/m/Y') }}</strong></li>
              <li>Type de projet : <strong>{{ application.projectHolder.useType }}</strong></li>
              <li>Type d'usage : <strong>{{ application.category }}</strong></li>
              <li>Départements souhaités : <strong>{% if application.projectHolder.preferredDepartmentsLabels|length %}{{ application.projectHolder.preferredDepartmentsLabels|join(', ') }}{% else %}—{% endif %}</strong></li>
              <li>Statut juridique (profil) : <strong>{% if application.projectHolder.companyStatus %}{{ application.projectHolder.companyStatus }}{% else %}—{% endif %}</strong></li>
              <li>Statut juridique (candidature) : <strong>{% if application.companyStatus %}{{ application.companyStatus }}{% else %}—{% endif %}</strong></li>
              <li>Surface souhaitée (profil) : <strong>{% if application.projectHolder.wishedSize %}{{ application.projectHolder.wishedSize }}{% else %}—{% endif %} m²</strong></li>
              <li>Surface souhaitée (candidature) : <strong>{% if application.wishedSize %}{{ application.wishedSize }}{% else %}—{% endif %} m²</strong></li>
              {% set _lengthValue = application.lengthOccupation ?: application.projectHolder.usageDuration %}
              {% set _lengthType = application.lengthTypeOccupation ?: application.projectHolder.lengthTypeOccupation %}
              <li>Durée d'occupation : <strong>{% if _lengthValue %}{{ _lengthValue }}{% if _lengthType %} {{ _lengthType }}{% endif %}{% else %}—{% endif %}</strong></li>
              <li>Date d'entrée souhaitée : <strong>{{ application.startOccupation|localizeddate('long', 'none', 'fr') }}</strong></li>
            </ul>

            <a href="{{ path('application_show', { 'id': application.id }) }}" class="btn btn-line-19"><span>Voir la candidature</span></a>
            </div>
        </div>
        </div>
      </div>
    </div>
      </div>
  {% else %}
    <div class="no-results">
      <p class="center">Il n'y a aucune candidature sur cet espace</p>
    </div>
  {% endfor %}
</div>

<div>
  <div class="row">
    <div class="col-sm-12">
      {{ knp_pagination_render(pagination) }}
    </div>
  </div>
</div>

<div style="display: none;">
    <div id="accept_content">
        <form action="{{ path('space_manager_candidates', {'id' : space.id}) }}#accept_confirm" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('candidates_action') }}" />
            <div class="colorBox-content">
                <h4>Accepter les candidatures selectionnées</h4>
                <br />
                <p class="text-left">Vous allez accepter les dossiers de <strong>$nb_candidates$ candidature(s)</strong>. Les candidats recevront le texte-type suivant :</p>

                <p class="text-left"><i>
                  Bonjour,<br>
                  Votre candidature sur le site plateau-urbain pour l'espace {{space.name}} à {{space.city}} a été acceptée.
                </i></p>

                <p class="text-left">
                  Souhaitez-vous compléter ce message ?
                </p>

                <textarea name="message" rows="5" class="form-control"></textarea>
                <input type="submit" value="Accepter" class="btn btn-fullcolor">
                <input type="hidden" name="action" value="accept" />
                <input type="hidden" name="applications" value="" />
            </div>
        </form>
    </div>
    <div id="refuse_content">
        <form action="{{ path('space_manager_candidates', {'id' : space.id}) }}#refuse_confirm" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('candidates_action') }}" />
            <div class="colorBox-content">
                <h4>Refuser les candidatures selectionnées</h4>
                <br />
                <p class="text-left">Vous allez effectuer un refus de <strong>$nb_candidates$ candidature(s)</strong>. Les candidats recevront le texte-type suivant :</p>

                <p class="text-left"><i>
                  Bonjour,<br>
                  Votre candidature sur le site plateau-urbain pour l'espace {{space.name}} à {{space.city}} a été refusée.
                </i></p>

                <p class="text-left">
                  Souhaitez-vous compléter ce message ?
                </p>

                <textarea name="message" rows="5" class="form-control"></textarea>
                <input type="submit" value="Envoyer un refus groupé" class="btn btn-fullcolor">
                <input type="hidden" name="action" value="refuse" />
                <input type="hidden" name="applications" value=""/>
            </div>
        </form>
    </div>
    <div id="accept_confirm">
        <div class="colorBox-content">
            <h4>Le message d'acceptation a été envoyé aux candidatures sélectionnées</h4>
            <br />
        </div>
    </div>
    <div id="refuse_confirm">
        <div class="colorBox-content">
            <h4>Le message de refus a été envoyé aux candidatures sélectionnées</h4>
            <br />
        </div>
    </div>
</div>

</div>
</div>

{% endblock %}

{% block javascript %}
    <script type="text/javascript" src="{{ asset('bundles/app/js/chart.min.js') }}"></script>

    <script type="text/javascript">
        $(document).ready(function() {

            $("#groupActionBtn").click(function(e) {
                e.preventDefault();
                var nbCandidates = $('.exportCheck:checked').length;

                var ids = '';
                $('.exportCheck:checked').each(function() {
                     ids += (ids === '' ? '' : '-') + $(this).val();
                });

                var action = $('#groupActionSelect').val();
                if (nbCandidates > 0 && action !== '') {
                    $('#accept_content input[name="applications"]').attr('value', ids);
                    $('#refuse_content input[name="applications"]').attr('value', ids);
                    var content = $('#' + action + '_content').html().replace(/\$nb_candidates\$/g, nbCandidates);
                    $.colorbox({ width: "500px", html: content });
                }
            });

            // Manage sort field
            $(function () {
                $('.sort').on('click', 'label', function () {
                    var $input = $(this).find('input');

                    $('.sort').find('label').removeClass('checked');

                    if ($input.is(':checked')) {
                        $(this).addClass('checked');
                    }
                });
            });

            // Submit form
            $('form[data-submit]').on('change', function () {
                // Sauvegarder la position du scroll avant la soumission
                var scrollKey = 'scroll_' + window.location.pathname;
                sessionStorage.setItem(scrollKey, window.pageYOffset);
                $(this).trigger('submit');
            });

            // Restaurer la position du scroll si elle est présente en session
            (function() {
                var scrollKey = 'scroll_' + window.location.pathname;
                var scrollPos = sessionStorage.getItem(scrollKey);
                if (scrollPos) {
                    window.scrollTo(0, scrollPos);
                    sessionStorage.removeItem(scrollKey);
                }
            })();

            var colors = ['#F7464A', '#46BFBD', '#FDB45C', '#949FB1', '#4D5360'];
            var hightLightColors = ['#FF5A5E', '#5AD3D1', '#FFC870', '#A8B3C5', '#616774'];

            // Créer un mapping entre les catégories et leurs couleurs
            var categoryColorMap = {};
            {% for key, cat in categories %}
            categoryColorMap[{{ cat.id }}] = colors[{{ key }} % 5];
            {% endfor %}

            // Créer un mapping pour les couleurs de hover
            var categoryHoverColorMap = {};
            {% for key, cat in categories %}
            categoryHoverColorMap[{{ cat.id }}] = hightLightColors[{{ key }} % 5];
            {% endfor %}

            // Appliquer les couleurs aux barres de gauche selon le type d'usage
            $('.actions[data-category]').each(function() {
                var $actions = $(this);
                var categoryId = $actions.attr('data-category');
                if (categoryId && categoryColorMap[categoryId]) {
                    var color = categoryColorMap[categoryId];
                    var hoverColor = categoryHoverColorMap[categoryId] || color;
                    $actions.css('background-color', color);
                    
                    // Stocker les couleurs pour le hover
                    $actions.data('category-color', color);
                    $actions.data('category-hover-color', hoverColor);
                }
            });

            // Gérer le hover avec la couleur du type d'usage (plus foncée)
            $('.candidate-item').hover(
                function() {
                    var $actions = $(this).find('.actions');
                    var hoverColor = $actions.data('category-hover-color');
                    if (hoverColor) {
                        $actions.css('background-color', hoverColor);
                    }
                },
                function() {
                    var $actions = $(this).find('.actions');
                    var categoryColor = $actions.data('category-color');
                    if (categoryColor) {
                        $actions.css('background-color', categoryColor);
                    }
                }
            );

            // ======================================================
            // GRAPHIQUE 1 : Répartition par département de la structure
            // ======================================================
            {% set allZipcodes = [] %}
            {% for app in space.application %}
                {% if app.status != constant('App\\Entity\\Application::DRAFT_STATUS') %}
                    {% set zip = (app.projectHolder ? app.projectHolder.zipcode : '') | trim %}
                    {% set allZipcodes = allZipcodes|merge([zip]) %}
                {% endif %}
            {% endfor %}

            var rawZipcodes = {{ allZipcodes|json_encode|raw }};
            var deptNames = {
                '01': 'Ain (01)', '02': 'Aisne (02)', '03': 'Allier (03)', '04': 'Alpes-de-Haute-Provence (04)', '05': 'Hautes-Alpes (05)',
                '06': 'Alpes-Maritimes (06)', '07': 'Ardèche (07)', '08': 'Ardennes (08)', '09': 'Ariège (09)', '10': 'Aube (10)',
                '11': 'Aude (11)', '12': 'Aveyron (12)', '13': 'Bouches-du-Rhône (13)', '14': 'Calvados (14)', '15': 'Cantal (15)',
                '16': 'Charente (16)', '17': 'Charente-Maritime (17)', '18': 'Cher (18)', '19': 'Corrèze (19)', '2A': 'Corse-du-Sud (2A)',
                '2B': 'Haute-Corse (2B)', '21': 'Côte-d\'Or (21)', '22': 'Côtes-d\'Armor (22)', '23': 'Creuse (23)', '24': 'Dordogne (24)',
                '25': 'Doubs (25)', '26': 'Drôme (26)', '27': 'Eure (27)', '28': 'Eure-et-Loir (28)', '29': 'Finistère (29)',
                '30': 'Gard (30)', '31': 'Haute-Garonne (31)', '32': 'Gers (32)', '33': 'Gironde (33)', '34': 'Hérault (34)',
                '35': 'Ille-et-Vilaine (35)', '36': 'Indre (36)', '37': 'Indre-et-Loire (37)', '38': 'Isère (38)', '39': 'Jura (39)',
                '40': 'Landes (40)', '41': 'Loir-et-Cher (41)', '42': 'Loire (42)', '43': 'Haute-Loire (43)', '44': 'Loire-Atlantique (44)',
                '45': 'Loiret (45)', '46': 'Lot (46)', '47': 'Lot-et-Garonne (47)', '48': 'Lozère (48)', '49': 'Maine-et-Loire (49)',
                '50': 'Manche (50)', '51': 'Marne (51)', '52': 'Haute-Marne (52)', '53': 'Mayenne (53)', '54': 'Meurthe-et-Moselle (54)',
                '55': 'Meuse (55)', '56': 'Morbihan (56)', '57': 'Moselle (57)', '58': 'Nièvre (58)', '59': 'Nord (59)',
                '60': 'Oise (60)', '61': 'Orne (61)', '62': 'Pas-de-Calais (62)', '63': 'Puy-de-Dôme (63)', '64': 'Pyrénées-Atlantiques (64)',
                '65': 'Hautes-Pyrénées (65)', '66': 'Pyrénées-Orientales (66)', '67': 'Bas-Rhin (67)', '68': 'Haut-Rhin (68)',
                '69': 'Rhône (69)', '70': 'Haute-Saône (70)', '71': 'Saône-et-Loire (71)', '72': 'Sarthe (72)', '73': 'Savoie (73)',
                '74': 'Haute-Savoie (74)', '75': 'Paris (75)', '76': 'Seine-Maritime (76)', '77': 'Seine-et-Marne (77)', '78': 'Yvelines (78)',
                '79': 'Deux-Sèvres (79)', '80': 'Somme (80)', '81': 'Tarn (81)', '82': 'Tarn-et-Garonne (82)', '83': 'Var (83)',
                '84': 'Vaucluse (84)', '85': 'Vendée (85)', '86': 'Vienne (86)', '87': 'Haute-Vienne (87)', '88': 'Vosges (88)',
                '89': 'Yonne (89)', '90': 'Territoire de Belfort (90)', '91': 'Essonne (91)', '92': 'Hauts-de-Seine (92)',
                '93': 'Seine-Saint-Denis (93)', '94': 'Val-de-Marne (94)', '95': 'Val-d\'Oise (95)',
                '971': 'Guadeloupe (971)', '972': 'Martinique (972)', '973': 'Guyane (973)', '974': 'La Réunion (974)', '976': 'Mayotte (976)'
            };

            var deptCounts = {};
            rawZipcodes.forEach(function(zip) {
                var dept = 'Non renseigné';
                if (zip && zip.length >= 2) {
                    if (zip.startsWith('97') && zip.length >= 3) {
                        dept = zip.substring(0, 3);
                    } else {
                        dept = zip.substring(0, 2);
                    }
                }
                deptCounts[dept] = (deptCounts[dept] || 0) + 1;
            });

            var deptData = Object.keys(deptCounts).map(function(dept) {
                var label = deptNames[dept] || (dept === 'Non renseigné' ? 'Non renseigné' : 'Département ' + dept);
                return { label: label, value: deptCounts[dept] };
            });

            deptData.sort(function(a, b) {
                if (b.value !== a.value) {
                    return b.value - a.value;
                }
                return a.label.localeCompare(b.label);
            });

            var maxDept = Math.max.apply(Math, deptData.map(function(d) { return d.value; }));
            if (maxDept === 0) maxDept = 1;

            var zipContainer = $('#zipcodeChart');
            zipContainer.empty();

            var zipColors = ['#5B9BD5', '#ED7D31', '#A5A5A5', '#FFC000', '#4472C4', '#70AD47', '#264478', '#9B59B6'];
            if (deptData.length === 0) {
                zipContainer.append('<div class="text-center text-muted" style="padding:20px 0;">Aucune donnée de département</div>');
            } else {
                deptData.forEach(function(item, idx) {
                    var pct = (item.value / maxDept) * 100;
                    var color = zipColors[idx % zipColors.length];
                    var valuePos = pct < 30 ? 'left:' + (pct + 2) + '%;' : 'left:' + pct + '%;transform:translateX(-100%) translateY(-50%);';
                    if (pct < 30) valuePos += 'transform:translateY(-50%);';

                    var html = '<div class="horizontal-bar-item">' +
                        '<div class="bar-label" title="' + item.label + '">' + item.label + '</div>' +
                        '<div class="bar-container">' +
                        '<div class="simple-bar-bg"><div class="simple-bar-fill" style="background:' + color + ';width:' + pct + '%;"></div>' +
                        '<span class="simple-bar-value" style="' + valuePos + 'top:50%;">' + item.value + ' candidature(s)</span>' +
                        '</div></div></div>';
                    zipContainer.append(html);
                });
            }

            // ======================================================
            // GRAPHIQUE 1b : Surface demandée par catégorie
            // ======================================================
            var surfaceData = [
                {% for key, cat in categories %}
                {% set catLabel = cat.name ~ (cat.isActive ? '' : ' (archivé)') %}
                {
                    label: {{ catLabel|json_encode|raw }},
                    value: {{ space.totalWishedSizeByCategory(cat) }},
                    count: {{ space.nbApplicationCategory(cat) }},
                    countWithSurface: {{ space.nbApplicationCategoryWithSurface(cat) }},
                    weightedAverage: {% set nbWithSurface = space.nbApplicationCategoryWithSurface(cat) %}{% if nbWithSurface > 0 %}{{ (space.totalWishedSizeByCategory(cat) / nbWithSurface)|number_format(1, '.', '') }}{% else %}0{% endif %},
                    color: colors[{{ key }} % 5]
                }{% if not loop.last %},{% endif %}
                {% endfor %}
            ];

            var maxSurface = Math.max.apply(Math, surfaceData.map(function(d) { return d.value; }));
            if (maxSurface === 0) maxSurface = 1;

            var surfaceContainer = $('#surfaceChart');
            surfaceContainer.empty();

            surfaceData.forEach(function(item) {
                var pct = (item.value / maxSurface) * 100;
                var valuePos = pct < 30 ? 'left:' + (pct + 2) + '%;' : 'left:' + pct + '%;transform:translateX(-100%) translateY(-50%);';
                if (pct < 30) valuePos += 'transform:translateY(-50%);';
                var weightedText = item.countWithSurface > 0
                    ? 'Moy. ' + item.weightedAverage + ' m² <small style="color:#aaa;" title="Calculée sur ' + item.countWithSurface + ' candidature(s) ayant renseigné une surface (sur ' + item.count + ' au total)">(' + item.countWithSurface + '/' + item.count + ')</small>'
                    : '<span style="color:#aaa;">Aucune surface renseignée</span>';

                var html = '<div class="horizontal-bar-item">' +
                    '<div class="bar-label">' + item.label + '</div>' +
                    '<div class="bar-container">' +
                    '<div class="simple-bar-bg"><div class="simple-bar-fill" style="background:' + item.color + ';width:' + pct + '%;"></div>' +
                    '<span class="simple-bar-value" style="' + valuePos + 'top:50%;">' + item.value + ' m²</span>' +
                    '</div><span class="simple-bar-subvalue" style="cursor:help;">' + weightedText + '</span></div></div>';
                surfaceContainer.append(html);
            });

            // ======================================================
            // GRAPHIQUE 3 : Par type de projet (barres horizontales)
            // ======================================================
            var usageColors = ['#5B9BD5', '#ED7D31', '#A5A5A5', '#FFC000', '#4472C4', '#70AD47', '#264478', '#9B59B6'];
            var usageData = [
                {% for key, use in useTypes %}
                {% set useLabel = use.name ~ (use.isActive ? '' : ' (archivé)') %}
                {
                    label: {{ useLabel|json_encode|raw }},
                    value: {{ space.nbApplicationUseType(use) }},
                    color: usageColors[{{ key }} % 8]
                }{% if not loop.last %},{% endif %}
                {% endfor %}
            ];

            var maxUsage = Math.max.apply(Math, usageData.map(function(d) { return d.value; }));
            if (maxUsage === 0) maxUsage = 1;

            var usageContainer = $('#usageChart');
            usageContainer.empty();

            usageData.forEach(function(item) {
                if (item.value === 0) return; // masquer les types sans candidature
                var pct = (item.value / maxUsage) * 100;
                var valuePos = pct < 30 ? 'left:' + (pct + 2) + '%;' : 'left:' + pct + '%;transform:translateX(-100%) translateY(-50%);';
                if (pct < 30) valuePos += 'transform:translateY(-50%);';

                var html = '<div class="horizontal-bar-item">' +
                    '<div class="bar-label">' + item.label + '</div>' +
                    '<div class="bar-container">' +
                    '<div class="simple-bar-bg"><div class="simple-bar-fill" style="background:' + item.color + ';width:' + pct + '%;"></div>' +
                    '<span class="simple-bar-value" style="' + valuePos + 'top:50%;">' + item.value + ' candidature(s)</span>' +
                    '</div></div></div>';
                usageContainer.append(html);
            });

            // ======================================================
            // GRAPHIQUE 5 : Statuts juridiques (candidature)
            // ======================================================
            var companyStatusColors = ['#4472C4', '#ED7D31', '#A5A5A5', '#FFC000'];
            var companyStatusData = [
                { label: 'Association',        value: {{ space.nbApplicationByCompanyStatus('Association') }},        color: companyStatusColors[0] },
                { label: 'Artiste',            value: {{ space.nbApplicationByCompanyStatus('Artiste') }},            color: companyStatusColors[1] },
                { label: 'Entreprise',         value: {{ space.nbApplicationByCompanyStatus('Entreprise') }},         color: companyStatusColors[2] },
                { label: 'Structure publique', value: {{ space.nbApplicationByCompanyStatus('Structure publique') }}, color: companyStatusColors[3] }
            ];

            var maxCompanyStatus = Math.max.apply(Math, companyStatusData.map(function(d) { return d.value; }));
            if (maxCompanyStatus === 0) maxCompanyStatus = 1;

            var companyStatusContainer = $('#companyStatusChart');
            companyStatusContainer.empty();

            companyStatusData.forEach(function(item) {
                var pct = (item.value / maxCompanyStatus) * 100;
                var valuePos = pct < 30 ? 'left:' + (pct + 2) + '%;' : 'left:' + pct + '%;transform:translateX(-100%) translateY(-50%);';
                if (pct < 30) valuePos += 'transform:translateY(-50%);';

                var html = '<div class="horizontal-bar-item">' +
                    '<div class="bar-label">' + item.label + '</div>' +
                    '<div class="bar-container">' +
                    '<div class="simple-bar-bg"><div class="simple-bar-fill" style="background:' + item.color + ';width:' + pct + '%;"></div>' +
                    '<span class="simple-bar-value" style="' + valuePos + 'top:50%;">' + item.value + ' candidature(s)</span>' +
                    '</div></div></div>';
                companyStatusContainer.append(html);
            });

            // ======================================================
            // GRAPHIQUE 4 : Timeline — candidatures par jour (ligne)
            // ======================================================
            var timelineRaw = [
                {% for app in space.application %}
                    {% if app.status != 'draft' %}
                    "{{ app.created|date('Y-m-d') }}"{% if not loop.last %},{% endif %}
                    {% endif %}
                {% endfor %}
            ];

            // Compter par jour
            var dayCounts = {};
            timelineRaw.forEach(function(d) {
                if (!d) return;
                dayCounts[d] = (dayCounts[d] || 0) + 1;
            });

            // Trier les clés par date
            var days = Object.keys(dayCounts).sort();

            if (days.length > 0) {
                // Remplir les jours manquants entre le premier et le dernier
                var startDate = new Date(days[0]);
                var endDate = new Date(days[days.length - 1]);
                var allDays = [];
                var currentDate = new Date(startDate);
                while (currentDate <= endDate) {
                    var key = currentDate.toISOString().slice(0, 10);
                    allDays.push({ date: key, count: dayCounts[key] || 0 });
                    currentDate.setDate(currentDate.getDate() + 1);
                }

                var maxCount = Math.max.apply(Math, allDays.map(function(d) { return d.count; }));
                if (maxCount === 0) maxCount = 1;

                // Dimensions du SVG
                var margin = { top: 20, right: 20, bottom: 50, left: 35 };
                var totalW = Math.max(500, allDays.length * 28 + margin.left + margin.right);
                var totalH = 220;
                var w = totalW - margin.left - margin.right;
                var h = totalH - margin.top - margin.bottom;

                var container = $('#timelineChartContainer');
                container.empty();
                container.css('width', totalW + 'px');

                // Construire le SVG
                var svg = '<svg class="line-chart-svg" width="' + totalW + '" height="' + totalH + '" viewBox="0 0 ' + totalW + ' ' + totalH + '">';

                // Dégradé pour l'aire sous la courbe
                svg += '<defs><linearGradient id="lineGradient" x1="0" y1="0" x2="0" y2="1">';
                svg += '<stop offset="0%" stop-color="#5B9BD5" stop-opacity="0.4"/>';
                svg += '<stop offset="100%" stop-color="#5B9BD5" stop-opacity="0.05"/>';
                svg += '</linearGradient></defs>';

                // Grille horizontale
                var nbGridLines = 4;
                for (var gi = 0; gi <= nbGridLines; gi++) {
                    var gy = margin.top + (h - (gi / nbGridLines) * h);
                    var gridVal = Math.round((gi / nbGridLines) * maxCount);
                    svg += '<line class="line-chart-grid" x1="' + margin.left + '" y1="' + gy + '" x2="' + (totalW - margin.right) + '" y2="' + gy + '" stroke="#e8e8e8" stroke-dasharray="3,3"/>';
                    svg += '<text class="line-chart-y-label" x="' + (margin.left - 6) + '" y="' + (gy + 3) + '" text-anchor="end">' + gridVal + '</text>';
                }

                // Calculer les points
                var points = [];
                allDays.forEach(function(d, i) {
                    var x = margin.left + (i / (allDays.length - 1 || 1)) * w;
                    var y = margin.top + h - (d.count / maxCount) * h;
                    points.push({ x: x, y: y, date: d.date, count: d.count });
                });

                // Aire sous la courbe
                var areaPath = 'M' + points[0].x + ',' + (margin.top + h);
                points.forEach(function(p) { areaPath += ' L' + p.x + ',' + p.y; });
                areaPath += ' L' + points[points.length - 1].x + ',' + (margin.top + h) + ' Z';
                svg += '<path class="line-chart-area" d="' + areaPath + '"/>';

                // Ligne
                var linePath = 'M';
                points.forEach(function(p, i) {
                    linePath += (i > 0 ? ' L' : '') + p.x + ',' + p.y;
                });
                svg += '<path class="line-chart-line" d="' + linePath + '"/>';

                // Points (dots)
                points.forEach(function(p) {
                    svg += '<circle class="line-chart-dot" cx="' + p.x + '" cy="' + p.y + '" r="4" data-date="' + p.date + '" data-count="' + p.count + '"/>';
                });

                // Labels de l'axe X (afficher un label sur N pour ne pas surcharger)
                var labelStep = Math.max(1, Math.ceil(allDays.length / 15));
                allDays.forEach(function(d, i) {
                    if (i % labelStep === 0 || i === allDays.length - 1) {
                        var x = margin.left + (i / (allDays.length - 1 || 1)) * w;
                        var parts = d.date.split('-');
                        var label = parts[2] + '/' + parts[1];
                        svg += '<text class="line-chart-axis-label" x="' + x + '" y="' + (totalH - 5) + '" text-anchor="middle" transform="rotate(-35,' + x + ',' + (totalH - 10) + ')">' + label + '</text>';
                    }
                });

                svg += '</svg>';
                container.html(svg);

                // Tooltip au survol des points
                var $tooltip = $('<div style="position:fixed;background:#333;color:#fff;padding:5px 10px;border-radius:4px;font-size:12px;pointer-events:none;display:none;z-index:9999;white-space:nowrap;"></div>').appendTo('body');

                container.on('mouseenter', '.line-chart-dot', function(e) {
                    var dateStr = $(this).attr('data-date');
                    var count = $(this).attr('data-count');
                    var parts = dateStr.split('-');
                    var label = parts[2] + '/' + parts[1] + '/' + parts[0];
                    $tooltip.text(label + ' — ' + count + ' candidature(s)').show();
                }).on('mousemove', '.line-chart-dot', function(e) {
                    $tooltip.css({ left: e.clientX + 12, top: e.clientY - 28 });
                }).on('mouseleave', '.line-chart-dot', function() {
                    $tooltip.hide();
                });
            } else {
                $('#timelineChartContainer').html('<p style="color:#999;font-style:italic;">Aucune donnée de timeline disponible.</p>');
            }
        });

        var hash = window.location.hash.substring(1);
        $(function() {

            if (hash == "accept_confirm") {
                $.colorbox({width:"400px", html:$('#accept_confirm').html()});
            } else if (hash == "refuse_confirm") {
                $.colorbox({width:"400px", html:$('#refuse_confirm').html()});
            }
        });

        // Gestion de la sélection pour l'export
        $(document).ready(function() {
            // Mettre à jour le compteur de sélection
            function updateSelectionCount() {
                var selectedCount = $('.exportCheck:checked').length;
                $('#selectedCount').text(selectedCount);
                $('#exportSelectedBtn').prop('disabled', selectedCount === 0);
            }

            // Écouter les changements sur les cases à cocher
            $(document).on('change', '.exportCheck', updateSelectionCount);

            // Bouton "Tout sélectionner"
            $('#selectAllBtn').click(function() {
                $('.exportCheck').prop('checked', true);
                updateSelectionCount();
            });

            // Bouton "Tout désélectionner"
            $('#selectNoneBtn').click(function() {
                $('.exportCheck').prop('checked', false);
                updateSelectionCount();
            });

            // Bouton "Sélectionner acceptées"
            $('#selectAcceptedBtn').click(function() {
                $('.exportCheck').prop('checked', false);
                $('.exportCheck[data-status="accepted"]').prop('checked', true);
                updateSelectionCount();
            });

            // Bouton "Sélectionner refusées"
            $('#selectRejectedBtn').click(function() {
                $('.exportCheck').prop('checked', false);
                $('.exportCheck[data-status="rejected"]').prop('checked', true);
                updateSelectionCount();
            });

            // Export des candidatures sélectionnées
            $('#exportSelectedBtn').click(function() {
                var selectedIds = [];
                $('.exportCheck:checked').each(function() {
                    selectedIds.push($(this).val());
                });

                if (selectedIds.length === 0) {
                    alert('Veuillez sélectionner au moins une candidature à exporter.');
                    return;
                }

                // Créer un formulaire pour envoyer les IDs sélectionnés
                var form = $('<form>', {
                    'method': 'POST',
                    'action': '{{ path("space_manager_candidatesexportzip_selected", {"id": space.id}) }}'
                });

                // Ajouter les IDs sélectionnés comme champs cachés
                selectedIds.forEach(function(id) {
                    form.append($('<input>', {
                        'type': 'hidden',
                        'name': 'selected_applications[]',
                        'value': id
                    }));
                });

                // Ajouter le token CSRF
                form.append($('<input>', {
                    'type': 'hidden',
                    'name': '_token',
                    'value': '{{ csrf_token("export_selected") }}'
                }));

                // Soumettre le formulaire
                $('body').append(form);
                form.submit();
                form.remove();
            });

            // Initialiser le compteur
            updateSelectionCount();
        });

    </script>
{% endblock %}
