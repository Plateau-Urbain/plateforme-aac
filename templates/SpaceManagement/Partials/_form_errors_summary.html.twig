{% macro render_form_errors(form, breadcrumbs) %}
    {% set breadcrumbs = breadcrumbs|default([]) %}
    {% set skipFields = ['publish', 'preview', 'save', 'draft', '_token'] %}

    {% for error in form.vars.errors|default([]) %}
        <li>
            {% if breadcrumbs|length %}
                <strong>{{ breadcrumbs|join(' › ') }} :</strong>
            {% endif %}
            {{ error.message }}
        </li>
    {% endfor %}

    {% for name, child in form %}
        {% if name not in skipFields %}
        {% set childBreadcrumbs = breadcrumbs %}
        {% if name matches '/^\\d+$/' %}
            {% set childBreadcrumbs = breadcrumbs|merge(['Lieu ' ~ (name + 1)]) %}
        {% else %}
            {% set label = child.vars.label|default('') %}
            {% if label is not same as(false) and label is not empty %}
                {% set childBreadcrumbs = breadcrumbs|merge([label]) %}
            {% elseif name == 'doc_aac' %}
                {% set childBreadcrumbs = breadcrumbs|merge(['Document d\'appel à candidature']) %}
            {% elseif name == 'doc_plan' %}
                {% set childBreadcrumbs = breadcrumbs|merge(['Répartition des espaces']) %}
            {% elseif name == 'doc_faq' %}
                {% set childBreadcrumbs = breadcrumbs|merge(['F.A.Q']) %}
            {% elseif name == 'locations' %}
                {% set childBreadcrumbs = breadcrumbs|merge(['Lieux proposés']) %}
            {% elseif name == 'type' %}
                {% set childBreadcrumbs = breadcrumbs|merge(['Type de locaux']) %}
            {% elseif name == 'price' %}
                {% set childBreadcrumbs = breadcrumbs|merge(['Prix']) %}
            {% elseif name == 'priceText' %}
                {% set childBreadcrumbs = breadcrumbs|merge(['Prix personnalisé']) %}
            {% endif %}
        {% endif %}
        {{ _self.render_form_errors(child, childBreadcrumbs) }}
        {% endif %}
    {% endfor %}
{% endmacro %}

{% import _self as formErrors %}

{% if form.vars.submitted and not form.vars.valid %}
<div class="alert alert-danger publish-errors-summary" role="alert">
    <strong>Publication impossible — points à corriger :</strong>
    <ul style="margin: 10px 0 0; padding-left: 20px;">
        {{ formErrors.render_form_errors(form) }}
    </ul>
</div>
{% endif %}
