<div class="col-sm-12">
  <div class="item application-space space-card list-aac {{ space.listingCardClass }}">
    

    <div class="row row-flex">
      <div class="col-xs-12 col-md-4">
        <div class="image">
          {% if space.isMultiLocation %}
            <span class="pu-multi-badge"><i class="fa fa-layer-group"></i> Multi-sites déjà ouvert</span>
          {% elseif space.isProposedByAdmin %}
            <span class="pu-managed-badge"><i class="fa fa-shield"></i> {{ space.managedByLabel ?: 'Géré par Plateau Urbain' }}</span>
          {% elseif space.owner and space.owner.company %}
            <span class="pu-owner-badge"><i class="fa fa-building"></i> Proposé par {{ space.owner.company }}</span>
          {% endif %}
          <div class="overlay">
            {% if space.isClosed %}
              <div class="clos"><p> Appel à candidature cloturé</p></div>
            {% elseif not space.isSubmitted and not space.isEnabled %}
              {% if space.submittedAt %}
                <div class="depublie"><p> Dépublié temporairement</p></div>
              {% else %}
                <div class="enedition"><p> En cours d'édition</p></div>
              {% endif %}
            {% elseif space.isSubmitted and not space.isEnabled %}
              <div class="enattente"><p> En attente de validation</p></div>
            {% elseif space.isSubmitted and space.isEnabled %}
              <div class="encours"><p> Appel à candidature en cours </p></div>
            {% endif %}
          </div>

          <div class="image-wrapper">
            <img src="{% if space.pics.0 is defined %}{{ vich_uploader_asset(space.pics.0, 'file') }}{% endif %}" alt="" />
          </div>
        </div>
      </div>

      <div class="col-xs-12 col-md-8 box-info">
        <div class="info">
          <div class="space-card-top-row">
            <div class="space-card-location-row">
              {% if space.isMultiLocation %}
                {% if space.displayCity|default(space.city) %}
                  <span class="ville">{{ space.displayCity|default(space.city) }} — {{ space.managedByLabel ?: 'géré par Plateau Urbain' }}</span>
                {% endif %}
              {% else %}
                <span class="ville">{{ space.displayCity|default(space.city) }}{% if space.displayZipCode|default(space.zipCode) %} ({{ (space.displayZipCode|default(space.zipCode))|slice(0,2) }}){% endif %}</span>
              {% endif %}
              <a href="{{ path('space_show', {'id': space.id}) }}" class="red space-card-view-link"><span class="sub-arrow"><i class="fa fa-square"></i></span>Voir l'annonce</a>
            </div>
            <h5>{{ space.name }}</h5>
            {% if space.size is not empty %}<p class="space-card-size">à partir de {{ space.size }}m<sup>2</sup></p>{% endif %}
          </div>

          <div class="row">
            <ul>
             
              <li>{{ space.type }}</li>
              <li>
                {% if space.priceText %}
                  {{ space.priceText }}
                {% else %}
                  À partir de: {{ space.price }}€/m²/mois
                {% endif %}
              </li>
              {% if not space.isMultiLocation and (space.nbSpaces or space.minSpace or space.maxSpace) %}
              <li>{{ space.nbSpaces }} espace(s)
              de {{ space.minSpace }} m<sup>2</sup> à {{ space.maxSpace }} m<sup>2</sup></li>
              {% endif %}
              </ul>
             </div>
          </div> 

        
           
             
              <div class="block-content">
                <div class="row row-flex">
                 <div class="col-xs-12 col-md-3">
                  <div class="candidats">
                  <i class="icon small user-brown"></i>
                    <h4>{{ space.nbValidApplication }}</h4> 
                  </div>
                    <h6>candidature(s)</h6>   
              </div>
                
                  <div class="col-xs-12 col-md-6 status-cards">
                    <div class="label-status awaiting">
                      <i class="fa fa-hourglass-half"></i>&nbsp;
                      {{ space.nbApplication(constant('App\\Entity\\Application::WAIT_STATUS'))  }} en attente
                    </div>
                  
                    <div class="label-status rejected">
                      <i class="fa fa-times"></i>&nbsp;
                      {{ space.nbApplication(constant('App\\Entity\\Application::REJECT_STATUS'))  }} refusées
                    </div>
                
                    <div class="label-status accepted">
                      <i class="fa fa-check"></i>&nbsp;
                      {{ space.nbApplication(constant('App\\Entity\\Application::ACCEPT_STATUS'))  }} acceptées
                    </div>
                  </div>
                  <div class="col-xs-12 col-md-3 space-card-side-link">
              <p><a href="{{ path('space_manager_candidates', {'id' : space.id}) }}" class="red"><span class="sub-arrow"><i class="fa fa-square"></i></span>Voir les candidats</a></p>
            </div>
                </div>
                  </div>  
                <div class="clearfix"></div>
              
            
        
            <div class="aac-action">
                 <div class="space-card-action-row">
                       <div class="space-card-deadline">
                            <div class="calendar"></div>
                            <div class="apply-date">
                            {% if space.isMultiLocation %}
                            <p class="apply-date-p">Candidatures</p>
                            <p class="apply-date-b">Ouvertes</p>
                            {% else %}
                            <p class="apply-date-p">Date limite de candidature</p>
                            <p class="apply-date-b">
                  {{ space.limitAvailability | localizeddate("long", "none", "fr") }} à {{ space.limitAvailability|date('H') }}h{{ space.limitAvailability|date('i') }}
                  </p>
                            {% endif %}
                            </div>
                       </div>

            <div class="space-card-actions align-btn">
              {# Bouton Modifier : seulement pour les espaces non soumis (brouillon) ou les admins #}
              {% if not space.isClosed %}
                {% if not space.submitted and not space.enabled %}
                  {# Espace en brouillon : tout le monde peut modifier #}
                  <a href="{{ path('space_manager_edit', { 'id': space.id }) }}" class="btn btn-line-19 "><span>Modifier</span></a>
                {% elseif space.submitted and not space.enabled and is_granted('ROLE_ADMIN') %}
                  {# Espace en attente : seuls les admins peuvent modifier #}
                  <a href="{{ path('space_manager_edit', { 'id': space.id }) }}" class="btn btn-line-19 "><span>Modifier</span></a>
                {% endif %}
              {% endif %}
            
              {% if space.isEnabled and not space.isClosed %}
                {% if app.user and is_granted('ROLE_ADMIN') %}
                  <form method="post" action="{{ path('space_manager_unpublish', {'id' : space.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_unpublish_' ~ space.id) }}">
                    <button type="submit" class="btn btn-line-19 btn-warning" onclick="return confirm('ADMIN : Suspendre temporairement cet espace pour modification ?\n\nAttention : Les candidats ne pourront plus voir l\'annonce jusqu\'à ce que vous la republiiez.\nPensez à modifier et republier rapidement.');"><span>Suspendre pour modification</span></button>
                  </form>
                  <form method="post" action="{{ path('space_manager_close', {'id' : space.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_close_' ~ space.id) }}">
                    <button type="submit" class="btn btn-line-19" onclick="return confirm('ADMIN : Êtes-vous sûr de vouloir clôturer cet espace ?\n\nCette action fermera définitivement l\'appel à candidatures.');"><span>Clôturer</span></button>
                  </form>
                {% else %}
                  <form method="post" action="{{ path('space_manager_unpublish', {'id' : space.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_unpublish_' ~ space.id) }}">
                    <button type="submit" class="btn btn-line-19 btn-warning" onclick="return confirm('Modifier cet AAC va le suspendre temporairement.\n\nLes candidats ne pourront plus voir l\'annonce jusqu\'à ce que vous la republiiez.\n\nVoulez-vous continuer ?');"><span>Modifier</span></button>
                  </form>
                  <form method="post" action="{{ path('space_manager_close', {'id' : space.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_close_' ~ space.id) }}">
                    <button type="submit" class="btn btn-line-19" onclick="return confirm('Êtes-vous sûr de vouloir clôturer cet espace ?');"><span>Clôturer</span></button>
                  </form>
                {% endif %}
              {% elseif not space.isEnabled %}
                {% if app.user and is_granted('ROLE_ADMIN') %}
                  <form method="post" action="{{ path('space_manager_delete', {'id' : space.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_delete_' ~ space.id) }}">
                    <button type="submit" class="btn btn-line-19" onclick="return confirm('ADMIN : Êtes-vous sûr de vouloir supprimer définitivement cet espace ?\n\nCette action est irréversible et supprimera :\n- L\'espace et toutes ses données\n- Toutes les candidatures associées\n- Tous les fichiers de candidatures\n\nATTENTION : Cette action ne peut pas être annulée.');"><span>Supprimer</span></button>
                  </form>
                {% else %}
                  <form method="post" action="{{ path('space_manager_delete', {'id' : space.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_delete_' ~ space.id) }}">
                    <button type="submit" class="btn btn-line-19" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet espace ?');"><span>Supprimer</span></button>
                  </form>
                {% endif %}
              {% endif %}
              
              {# Bouton de publication pour les admins uniquement #}
              {% if app.user and space.submitted and not space.enabled %}
                {% if is_granted('ROLE_ADMIN') %}
                  <form method="post" action="{{ path('space_manager_publish', {'id' : space.id}) }}" style="display:inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('space_publish_' ~ space.id) }}">
                    <button type="submit" class="btn btn-line-19 btn-success" onclick="return confirm('ADMIN : Êtes-vous sûr de vouloir approuver et publier cet espace ?\n\nL\'espace sera immédiatement visible par tous les candidats et le propriétaire sera notifié par email.');"><span>Approuver et Publier</span></button>
                  </form>
                {% else %}
                  <span class="text-warning" style="display: inline-block; padding: 10px; background: #fff3cd; border-radius: 4px; margin-top: 10px;">
                    <i class="fa fa-hourglass-half"></i> Votre espace est en attente de validation par un administrateur. Vous serez notifié par email une fois publié.
                  </span>
                {% endif %}
              {% endif %}
            </div>
         </div>

          </div>  
        </div>
      </div>

  </div>
</div>


