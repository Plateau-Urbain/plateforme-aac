<script>
(function () {
    // Mapping section id -> index de l'indicateur (0-based)
    var sections = ['one', 'two', 'three', 'four', 'five'];

    // Chercher la première section contenant au moins un champ en erreur
    var targetSection = null;
    var targetIndex   = -1;

    for (var i = 0; i < sections.length; i++) {
        var section = document.getElementById(sections[i]);
        if (section && section.querySelector('.has-error')) {
            targetSection = section;
            targetIndex   = i;
            break;
        }
    }

    if (!targetSection) {
        return; // Aucune erreur de validation inline, rien à faire
    }

    // Mettre en évidence l'indicateur latéral correspondant
    var indicators = document.querySelectorAll('.bkg .indicator');
    indicators.forEach(function (el) { el.classList.remove('active'); });
    if (indicators[targetIndex]) {
        indicators[targetIndex].classList.add('active');
    }

    // Scroll doux vers la section fautive
    targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
})();
</script>



