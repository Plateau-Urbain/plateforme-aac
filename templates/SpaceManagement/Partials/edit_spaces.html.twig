{% set photoUploadError = app.flashes('photo_upload')|last|default(null) %}
{% set allFlashes = app.flashes %}

{% if allFlashes|length %}
<div class="container" style="margin-top: 25px; margin-bottom: 25px; position: relative; z-index: 10;">
    {% for label, messages in allFlashes %}
        {% if label != 'photo_upload' %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'success' ? 'success' : (label == 'warning' ? 'warning' : 'info')) }} alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Fermer"><span aria-hidden="true">&times;</span></button>
                {{ message }}
            </div>
        {% endfor %}
        {% endif %}
    {% endfor %}
</div>
{% endif %}

{% form_theme form 'Form/bootstrap_3_layout.html.twig' %}
<style>
    /* Le fond du formulaire n'étant pas garanti (variable selon la section),
       le message d'erreur porte son propre fond pour rester lisible dans tous les cas. */
    #js-form-space .has-error .help-block {
        display: block;
        color: #FFF;
        background-color: #e9473c;
        font-size: 13px;
        margin-top: 4px;
