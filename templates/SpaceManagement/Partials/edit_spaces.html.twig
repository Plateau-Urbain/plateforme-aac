        min-width: 0;
    }
    #js-form-space .limit-availability-datetime__hour,
    #js-form-space .limit-availability-datetime__minute {
        flex: 1 1 calc(50% - 5px);
        min-width: 0;
    }
    @media (min-width: 768px) {
        #js-form-space .limit-availability-datetime {
