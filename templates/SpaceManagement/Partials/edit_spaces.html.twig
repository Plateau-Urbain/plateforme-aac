        }
    }
    #js-form-space .space-form-add-row__field .form-control,
    #js-form-space .space-form-add-row__field .overflow {
        height: 42px;
        margin-bottom: 0;
    }
    #js-form-space .space-form-add-row__action .btn {
        margin-bottom: 0;
        width: 100%;
    }
    #js-form-space .space-surfaces-row {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 10px;
        margin-bottom:15px;
    }
    #js-form-space .space-surfaces-row > .form-group {
        flex: 1 1 100%;
        min-width: 0;
        margin-bottom: 0;
    }
    @media (min-width: 768px) {
        #js-form-space .space-surfaces-row {
            flex-wrap: nowrap;
           
        }
        #js-form-space .space-surfaces-row > .form-group {
            flex: 1 1 33%;
        }
    }
    #js-form-space .space-price-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
         margin-bottom:15px;
    }
    #js-form-space .space-price-row__fields {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        gap: 10px;
        flex: 1 1 100%;
        min-width: 0;
    }
    #js-form-space .space-price-row__fields > .form-group {
        flex: 1 1 100%;
        min-width: 0;
        margin-bottom: 0;
    }
    #js-form-space .space-price-row__fields > .form-group .help-block {
