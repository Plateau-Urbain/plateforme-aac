{% extends "base.html.twig" %}

{% block body %}
<div class="white"> 
        <div class="container"> 
   <div class="bkg-img"></div>
     
    <div class="row top-profil">
        <!-- BEGIN MAIN CONTENT -->
        <div class=" col-sm-12 ">

            <div class="titre-page">
                <h1>Mon profil candidat</h1>
            </div>
           <h6> <a href="{{ path('search_index') }}" class="red"><span class="sub-arrow"><i class="fa fa-square"></i></span>Tous les appels à candidatures</a></h6>
            {# <p>Voir les <a href="{{ path('cgu') }}">Conditions générales d'utilisation</a></p> #}
            
            {% if next is defined and next %}
                <div class="alert alert-info" role="alert">
                    <i class="fa fa-info-circle"></i>
                    <strong>Information :</strong> Mettez à jour votre profil. Une fois vos modifications enregistrées, vous serez automatiquement redirigé vers votre candidature.
                </div>
            {% endif %}
        </div>
    </div>

    <div id="js-form-space"{% if form.vars.value.useType is not null and not form.vars.value.useType.isActive %} data-use-type-archived="1"{% endif %}>
    
        {% for message in  app.flashes('error_msg') %}
            <div class="alert alert-danger" role="alert">
                {{ message }}
            </div>
        {% endfor %}
    
    
        {% for message in  app.flashes('success_msg') %}
            <div class="alert alert-success" role="alert">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning" role="alert">
                {{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger" role="alert">
                {{ message }}
            </div>
        {% endfor %}

        {% if form.vars.value.useType is not null and not form.vars.value.useType.isActive %}
            <div class="alert alert-warning" role="alert">
                <strong>Type de projet :</strong>
                la valeur enregistrée n’est plus proposée sur la plateforme. Vous devez en sélectionner une nouvelle dans la section « Mes souhaits » (en bas du formulaire), puis enregistrer.
            </div>
        {% endif %}

        {% if form.vars.submitted is defined and form.vars.submitted and form.vars.valid is defined and not form.vars.valid and form.useType.vars.errors|length %}
            <div id="js-profile-usetype-validation-alert" class="alert alert-danger" role="alert">
                <strong>Enregistrement impossible.</strong>
                {% for error in form.useType.vars.errors %}
                    {{ error.message }}
                {% endfor %}
                Rendez-vous dans la section « Mes souhaits » pour choisir un type de projet actuellement proposé.
            </div>
        {% endif %}
        <div id="js-profile-incomplete-banner" style="display:none; position:relative; z-index:10;" role="alert" aria-live="polite"></div>

        {# Si on arrive depuis apply, conserver next aussi dans l'action du form #}
        {% set formAction = (next is defined and next) ? path('security_profil_role', { 'role': 'candidat', 'next': next, 'return_anchor': (return_anchor is defined ? return_anchor : null) }) : null %}
        {{ form_start(form, {
            'action': formAction,
            'attr': {'class': 'has-crosses', 'novalidate': 'novalidate'}
        }) }}
        {# Propager la redirection vers la candidature après mise à jour du profil #}
        {% if next is defined and next %}
            <input type="hidden" name="next" value="{{ next }}" />
            {% if return_anchor is defined and return_anchor %}
                <input type="hidden" name="return_anchor" value="{{ return_anchor }}" />
            {% endif %}
        {% endif %}
            <div class="row">
                <div class=" col-xs-1 bkg ">
                    <ul>
                        <li>
                            <a class="indicator active" href="#one"></a>
                        </li>
                        <li>
                            <a class="indicator" href="#two"></a>
                        </li>
                        <li>
                            <a class="indicator" href="#three"></a>
                        </li>
                        <li>
                            <a class="indicator" href="#four"></a>
                        </li>
                        <li>
                            <a class="indicator" href="#five"></a>
                        </li>
                    </ul>
                </div>
                <div class="main col-xs-10 ">

                    <div id="one" class="section">
                        <span class="section-title form-one"></span>
                        <div class="form-contener">
                            <h3>Mes informations</h3>
                            <div class="row">
                                 <div class="col-sm-6 inline-controls form-group civility-group{% if form.userInfo.civility.vars.errors|length %} has-error{% endif %}">
                                     {{ form_label(form.userInfo.civility, null, {'label_attr': {'class': 'required'}}) }}
                                     {{ form_widget(form.userInfo.civility, { 
                                         'label_attr': { 'class': 'radio-inline' },
                                         'attr': {
                                             'aria-required': 'true',
                                             'aria-invalid': form.userInfo.civility.vars.errors|length ? 'true' : 'false',
                                             'aria-describedby': 'civility-error'
                                         }
                                     }) }}
                                     {% if form.userInfo.civility.vars.errors|length %}
                                         <span class="help-block js-help-block" role="alert" aria-live="polite">
                                             {{ form_errors(form.userInfo.civility) }}
                                         </span>
                                     {% endif %}
                                 </div>
                             </div>
                             <div class="row">
                                 <div class="col-sm-6 form-group{% if form.userInfo.firstname.vars.errors|length %} has-error{% endif %}">
                                     {{ form_label(form.userInfo.firstname, null, {'label_attr': {'class': 'required'}}) }}
                                     {{ form_widget(form.userInfo.firstname, {
                                         'attr': {
                                             'required': 'required',
                                             'aria-required': 'true',
                                             'aria-invalid': form.userInfo.firstname.vars.errors|length ? 'true' : 'false',
                                             'aria-describedby': 'firstname-error',
                                             'data-error-message': 'Veuillez renseigner votre prénom'
                                         }
                                     }) }}
                                     {% if form.userInfo.firstname.vars.errors|length %}
                                         <span class="help-block js-help-block" role="alert" aria-live="polite">
                                             {{ form_errors(form.userInfo.firstname) }}
                                         </span>
                                     {% endif %}
                                 </div>
                                 <div class="col-sm-6 form-group{% if form.userInfo.lastname.vars.errors|length %} has-error{% endif %}">
                                     {{ form_label(form.userInfo.lastname, null, {'label_attr': {'class': 'required'}}) }}
                                     {{ form_widget(form.userInfo.lastname, {
                                         'attr': {
                                             'required': 'required',
                                             'aria-required': 'true',
                                             'aria-invalid': form.userInfo.lastname.vars.errors|length ? 'true' : 'false',
                                             'aria-describedby': 'lastname-error',
                                             'data-error-message': 'Veuillez renseigner votre nom'
                                         }
                                     }) }}
                                     {% if form.userInfo.lastname.vars.errors|length %}
                                         <span class="help-block js-help-block" role="alert" aria-live="polite">
                                             {{ form_errors(form.userInfo.lastname) }}
                                         </span>
                                     {% endif %}
                                 </div>
                             </div>
                             <div class="row">
                                 <div class="col-sm-6 form-group{% if form.userInfo.birthday.vars.errors|length %} has-error{% endif %}">
                                     {{ form_label(form.userInfo.birthday) }}
                                     {{ form_widget(form.userInfo.birthday) }}
                                     {% if form.userInfo.birthday.vars.errors|length %}
                                         <span class="help-block js-help-block" role="alert" aria-live="polite">
                                             {{ form_errors(form.userInfo.birthday) }}
                                         </span>
                                     {% endif %}
                                 </div>
                                 <div class="col-sm-6 form-group{% if form.userInfo.phone.vars.errors|length %} has-error{% endif %}">
                                     {{ form_label(form.userInfo.phone) }}
                                     {{ form_widget(form.userInfo.phone) }}
                                     {% if form.userInfo.phone.vars.errors|length %}
                                         <span class="help-block js-help-block" role="alert" aria-live="polite">
                                             {{ form_errors(form.userInfo.phone) }}
                                         </span>
                                     {% endif %}
                                 </div>
                             </div>
                             <div class="row">
                                 <div class="col-sm-12 form-group{% if form.userInfo.email.vars.errors|length %} has-error{% endif %}">
                                     {{ form_label(form.userInfo.email) }}
                                     {{ form_widget(form.userInfo.email) }}
                                     {% if form.userInfo.email.vars.errors|length %}
                                         <span class="help-block js-help-block" role="alert" aria-live="polite">
                                             {{ form_errors(form.userInfo.email) }}
                                         </span>
                                     {% endif %}
                                     <small class="help-block text-muted">
                                         <i class="fa fa-info-circle"></i> 
                                         L'adresse email ne peut pas être modifiée après la création du compte. 
                                     </small>
                                </div>
                            </div>
                            <div class="row form-group">
                                <div class="col-sm-12 ">
                                    {{ form_row(form.newsletter) }}
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="two" class="section">
                        <span class="section-title form-two"></span>
                        <div class="form-contener">
                            <h3>Ma structure</h3>
                            
                            <h4 style="margin: 20px 15px 15px 15px; font-size: 14px; font-weight: bold; border-bottom: 1px solid rgba(0,0,0,0.15); padding-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; color: #333;">1. Informations administratives</h4>
                            
                            <div class="row">
                                <div class="col-sm-6 form-group{% if form.companyInfo.company.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.company) }}
                                    {{ form_widget(form.companyInfo.company) }}
                                    {% if form.companyInfo.company.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.company) }}
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="col-sm-6 form-group{% if form.companyInfo.companyStatus.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.companyStatus) }}
                                    {{ form_widget(form.companyInfo.companyStatus) }}
                                    {% if form.companyInfo.companyStatus.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.companyStatus) }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-6 form-group{% if form.useType.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.useType, "Secteur d'activité", {'label_attr': {'class': 'required'}}) }}
                                    {{ form_widget(form.useType) }}
                                    {{ form_errors(form.useType, {
                                        'attr': {
                                            'id': 'useType-error',
                                            'role': 'alert',
                                            'aria-live': 'polite'
                                        }
                                    }) }}
                                </div>
                                <div class="col-sm-6 form-group">
                                    {{ form_row(form.companyInfo.isSubjectToVat) }}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-6  form-group{% if form.companyInfo.companyCreationDate.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.companyCreationDate) }}
                                    {{ form_widget(form.companyInfo.companyCreationDate) }}
                                    {% if form.companyInfo.companyCreationDate.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.companyCreationDate) }}
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="col-sm-6  form-group{% if form.companyInfo.siret.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.siret) }}
                                    {{ form_widget(form.companyInfo.siret) }}
                                    {% if form.companyInfo.siret.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.siret) }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>

                            <h4 style="margin: 30px 15px 15px 15px; font-size: 14px; font-weight: bold; border-bottom: 1px solid rgba(0,0,0,0.15); padding-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; color: #333;">2. Statut coopératif</h4>
                            <div class="row">
                                <div class="col-sm-6 form-group">
                                    {{ form_row(form.companyInfo.isPuShareholder) }}
                                </div>
                            </div>
                            
                            <h4 style="margin: 30px 15px 15px 15px; font-size: 14px; font-weight: bold; border-bottom: 1px solid rgba(0,0,0,0.15); padding-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; color: #333;">3. Coordonnées</h4>
                            
                            <div class="row">
                                <div class="col-sm-12 form-group{% if form.companyInfo.address.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.address) }}
                                    {{ form_widget(form.companyInfo.address) }}
                                    {% if form.companyInfo.address.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.address) }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-6 form-group{% if form.companyInfo.zipcode.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.zipcode) }}
                                    {{ form_widget(form.companyInfo.zipcode) }}
                                    {% if form.companyInfo.zipcode.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.zipcode) }}
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="col-sm-6 form-group{% if form.companyInfo.city.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.city) }}
                                    {{ form_widget(form.companyInfo.city) }}
                                    {% if form.companyInfo.city.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.city) }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-6 form-group{% if form.companyInfo.companyPhone.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.companyPhone) }}
                                    {{ form_widget(form.companyInfo.companyPhone) }}
                                    {% if form.companyInfo.companyPhone.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.companyPhone) }}
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="col-sm-6 form-group{% if form.companyInfo.companyMobile.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.companyMobile) }}
                                    {{ form_widget(form.companyInfo.companyMobile) }}
                                    {% if form.companyInfo.companyMobile.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.companyMobile) }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            
                            <h4 style="margin: 30px 15px 15px 15px; font-size: 14px; font-weight: bold; border-bottom: 1px solid rgba(0,0,0,0.15); padding-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; color: #333;">4. Fonctionnement &amp; Présentation</h4>
                            
                            <div class="row">
                                <div class="col-sm-12 form-group{% if form.companyInfo.companyDescription.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.companyDescription) }}
                                    {{ form_widget(form.companyInfo.companyDescription, {'attr': {'placeholder': 'Présentez votre structure (emojis non autorisés)'}}) }}
                                    {% if form.companyInfo.companyDescription.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.companyDescription) }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-6 form-group{% if form.companyInfo.companyEffective.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.companyEffective) }}
                                    {{ form_widget(form.companyInfo.companyEffective) }}
                                    {% if form.companyInfo.companyEffective.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.companyEffective) }}
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="col-sm-6 form-group{% if form.companyInfo.companyStructures.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.companyInfo.companyStructures) }}
                                    {{ form_widget(form.companyInfo.companyStructures) }}
                                    {% if form.companyInfo.companyStructures.vars.errors|length %}
                                        <span class="help-block js-help-block" role="alert" aria-live="polite">
                                            {{ form_errors(form.companyInfo.companyStructures) }}
                                        </span>
                                    {% endif %}
                                </div>
                            </div>


                        </div>

                    </div>

                    <span id="three" class="section"></span>
                    <span class="section-title form-three"></span>
                    <div class="form-contener">
                        <h3>Site internet &amp; Réseaux sociaux</h3>
                        <small class="help-block text-muted" style="margin-bottom: 20px; display: block; font-size: 13px;">
                            <i class="fa fa-info-circle"></i> Tous les liens doivent être saisis sous forme d'URL complètes commençant par <strong>http://</strong> ou <strong>https://</strong>.
                        </small>
                        <div class="row">
                            <div class="col-sm-6 form-group{% if form.companyInfo.companySite.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon"><i class="fa fa-globe fa-lg"></i></span>
                                    {{ form_widget(form.companyInfo.companySite, {'attr': {'placeholder': 'Site internet (ex: https://www.monsite.fr)'}}) }}
                                </div>
                                {{ form_errors(form.companyInfo.companySite) }}
                            </div>
                            <div class="col-sm-6 form-group{% if form.facebookUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon"><i class="fa-brands fa-facebook-f fa-lg"></i></span>
                                    {{ form_widget(form.facebookUrl, {'attr': {'placeholder': 'Facebook (ex: https://www.facebook.com/nompage)'}}) }}
                                </div>
                                {{ form_errors(form.facebookUrl) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 form-group{% if form.twitterUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon" aria-label="X (anciennement Twitter)">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1.33em" height="1.33em" fill="currentColor" aria-hidden="true" focusable="false" role="img">
                                            <path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/>
                                        </svg>
                                    </span>
                                    {{ form_widget(form.twitterUrl, {'attr': {'placeholder': 'Twitter / X (ex: https://x.com/nomcompte)'}}) }}
                                </div>
                                {{ form_errors(form.twitterUrl) }}
                            </div>
                            <div class="col-sm-6 form-group{% if form.linkedinUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon"><i class="fa-brands fa-linkedin-in fa-lg"></i></span>
                                    {{ form_widget(form.linkedinUrl, {'attr': {'placeholder': 'LinkedIn (ex: https://www.linkedin.com/in/nomprofil)'}}) }}
                                </div>
                                {{ form_errors(form.linkedinUrl) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 form-group{% if form.instagramUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon"><i class="fa-brands fa-instagram fa-lg"></i></span>
                                    {{ form_widget(form.instagramUrl, {'attr': {'placeholder': 'Instagram (ex: https://www.instagram.com/nomcompte)'}}) }}
                                </div>
                                {{ form_errors(form.instagramUrl) }}
                            </div>
                            <div class="col-sm-6 form-group{% if form.youtubeUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon"><i class="fa-brands fa-youtube fa-lg"></i></span>
                                    {{ form_widget(form.youtubeUrl, {'attr': {'placeholder': 'YouTube (ex: https://www.youtube.com/@nomchaine)'}}) }}
                                </div>
                                {{ form_errors(form.youtubeUrl) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 form-group{% if form.tiktokUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon"><i class="fa-brands fa-tiktok fa-lg"></i></span>
                                    {{ form_widget(form.tiktokUrl, {'attr': {'placeholder': 'TikTok (ex: https://www.tiktok.com/@nomcompte)'}}) }}
                                </div>
                                {{ form_errors(form.tiktokUrl) }}
                            </div>
                            <div class="col-sm-6 form-group{% if form.googleUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon" aria-label="Bluesky">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 530" width="1.33em" height="1.33em" fill="currentColor" aria-hidden="true" focusable="false" role="img">
                                            <path d="m135.72 44.03c66.5 49.92 138.02 151.14 164.28 205.46 26.26-54.32 97.78-155.54 164.28-205.46 47.98-36.021 125.72-63.892 125.72 24.795 0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3797-3.6904-10.832-3.7077-7.8964-0.0174-2.9357-1.1937 0.51669-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4491-163.25-81.433-5.9562-21.282-16.111-152.36-16.111-170.07 0-88.687 77.742-60.816 125.72-24.795z"/>
                                        </svg>
                                    </span>
                                    {{ form_widget(form.googleUrl, {'attr': {'placeholder': 'Bluesky (ex: https://bsky.app/profile/nomcompte)'}}) }}
                                </div>
                                {{ form_errors(form.googleUrl) }}
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-6 form-group{% if form.otherUrl.vars.errors|length %} has-error{% endif %}">
                                <div class="input-group social-group">
                                    <span class="input-group-addon"><i class="fa fa-link fa-lg"></i></span>
                                    {{ form_widget(form.otherUrl, {'attr': {'placeholder': 'Autre URL (ex: https://...)'}}) }}
                                </div>
                                {{ form_errors(form.otherUrl) }}
                            </div>
                        </div>
                    </div>

                    <span id="four" class="section"></span>
                    <span class="section-title form-four"></span>
                    <div class="form-contener">
                        <h3>Mes documents</h3>
                        <div class="row">
                            <div class="col-sm-12 required-files">
                                <div class="col-sm-6">
                                    <label class="control-label">Mes téléchargements</label>

                                    <dl class="dl-horizontal info-block">

                                        <dd>
                                        Les documents suivants seront attachés à toutes vos candidatures.
