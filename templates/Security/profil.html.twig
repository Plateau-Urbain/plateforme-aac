{% block javascript %}
    <script>
        // Défilement automatique seulement s'il y a des erreurs de validation visibles
        // Ignorer les messages informatifs (text-muted) et ne garder que les erreurs réelles
        if (document.querySelector('.form-group.has-error .help-block:not(.text-muted), .file-infos.has-error .help-block, #js-profile-usetype-validation-alert')) {
            setTimeout(function() {
                const topAlert = document.querySelector('#js-profile-usetype-validation-alert');
                if (topAlert) {
                    topAlert.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }
                const firstError = document.querySelector('.form-group.has-error .help-block:not(.text-muted), .file-infos.has-error .help-block');
                if (firstError) {
                    const scrollTarget = firstError.closest('.form-group') || firstError.closest('.file-infos');
                    if (scrollTarget) scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }, 500);
        }
        
        $(document).ready(function() {
            // Avertissements au chargement pour les champs nouveaux ou modifiés.
            // Utilise un style ambre (non bloquant) distinct des erreurs rouges.
            // Uniquement pour les utilisateurs existants (firstName déjà renseigné).
            const $firstNameField = $('input[name*="firstname"], input[name*="firstName"]');
            const isExistingUser = $firstNameField.length && $firstNameField.val().trim() !== '';

            // Définition des champs à surveiller avec leur ancre de section
            const newFieldWarnings = [
                {
                    id:       'warn-birthday',
                    selector: 'input[name*="birthday"]',
                    label:    'Date de naissance',
                    message:  '📅 Ce champ a évolué : veuillez vérifier et confirmer votre date de naissance.',
                    anchor:   '#one'
                },
                {
                    id:       'warn-companyCreationDate',
                    selector: 'input[name*="companyCreationDate"]',
                    label:    'Date de création de la structure',
                    message:  '📅 Ce champ a évolué : veuillez vérifier et confirmer la date de création de votre structure.',
                    anchor:   '#two'
                },
                {
                    id:       'warn-monthlyBudgetMax',
                    selector: 'input[name*="monthlyBudgetMax"]',
                    label:    'Budget mensuel maximum',
                    message:  'Nouveau champ obligatoire : veuillez renseigner votre budget mensuel maximum.',
                    anchor:   '#five'
                },
                {
                    id:       'warn-preferredDepartments',
                    selector: null, // traité séparément via $prefDeptLoad
                    label:    'Zone géographique souhaitée',
                    message:  'Nouveau champ obligatoire : veuillez sélectionner au moins un département.',
                    anchor:   '#five'
                },
                {
                    id:       'warn-useType',
                    selector: null, // traité séparément via $useTypeField
                    label:    'Type de projet',
                    message:  'Nouveau champ obligatoire : veuillez sélectionner un type de projet.',
                    anchor:   '#five'
                },
                {
                    id:       'warn-useType-archived',
                    selector: null,
                    label:    'Type de projet (archivé)',
                    message:  'Le type enregistré n\'est plus proposé : choisissez-en un autre dans la liste.',
                    anchor:   '#five'
                }
            ];

            // Bandeau récapitulatif en haut de page
            const $banner = $('#js-profile-incomplete-banner');

            function buildBanner(missingIds) {
                if (!missingIds.length) {
                    $banner.hide().empty();
                    return;
                }
                $banner.html(
                    '<div style="padding:14px 18px;margin-bottom:16px;">' +
                    '<strong style="color:#bc1b38;">⚠ Votre profil doit être complété pour pouvoir candidater</strong>' +
                    '<p style="margin:8px 0 0 0;color:#000;">Des champs de votre profil sont manquants ou ont été mis à jour depuis votre dernière connexion. ' +
                    'Merci de <strong>relire et compléter l\'ensemble des sections de votre profil</strong> (coordonnées, présentation, projet, réseaux sociaux…) ' +
                    'avant de déposer une candidature.</p>' +
                    '</div>'
                ).show();
            }

            // Calcul initial des champs manquants
            function getMissingIds() {
                const missing = [];
                newFieldWarnings.forEach(function(cfg) {
                    if (!cfg.selector) return; // preferredDepartments traité en dehors
                    const $field = $(cfg.selector);
                    if (!$field.length) return;
                    const val = $field.val();
                    if (!val || val.trim() === '') missing.push(cfg.id);
                });
                // preferredDepartments
                const $pd = $('#project_owner_preferredDepartments');
                if ($pd.length) {
                    const v = $pd.val();
                    const empty = !v || (Array.isArray(v) ? v.length === 0 : String(v).trim() === '');
                    if (empty) missing.push('warn-preferredDepartments');
                }
                // useType vide (pas archivé — l'alerte Twig statique couvre déjà ce cas)
                const $ut = $('#project_owner_useType');
                if ($ut.length && $('#js-form-space').attr('data-use-type-archived') !== '1') {
                    const utVal = $ut.val();
                    const utEmpty = !utVal || String(utVal).trim() === '';
                    if (utEmpty) missing.push('warn-useType');
                }
                return missing;
            }

            function removeMissingId(id) {
                const items = $banner.find('li');
                items.each(function() {
                    if ($(this).find('a').data('field-id') === id) $(this).remove();
                });
                if ($banner.find('li').length === 0) $banner.hide().empty();
            }

            if (isExistingUser || !$('#project_owner_useType').val()) {
                buildBanner(getMissingIds());
            }

            // Clic sur un lien du bandeau → scroll vers la section puis vers le champ
            $(document).on('click', '.js-banner-scroll-link', function(e) {
                e.preventDefault();
                const anchor = $(this).data('anchor');
                const $section = $(anchor);
                if ($section.length) {
                    $section[0].scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });

            // Avertissements individuels sur chaque champ + mise à jour du bandeau
            newFieldWarnings.forEach(function(cfg) {
                if (!isExistingUser || !cfg.selector) return;
                const $field = $(cfg.selector);
                if (!$field.length) return;
                const val = $field.val();
                const isEmpty = !val || val.trim() === '';
                if (!isEmpty) return; // déjà renseigné

                const formGroup = $field.closest('.form-group');
                if (!formGroup.find('.help-block-new').length) {
                    formGroup.addClass('has-warning-new');
                    formGroup.append('<span class="help-block-new" role="note">' + cfg.message + '</span>');
                }

                $field.one('change blur', function() {
                    if ($(this).val().trim() !== '') {
                        formGroup.removeClass('has-warning-new');
                        formGroup.find('.help-block-new').remove();
                        removeMissingId(cfg.id);
                    }
                });
            });

            // preferredDepartments : avertissement individuel + bandeau
            const $prefDeptLoad = $('#project_owner_preferredDepartments');
            if ($prefDeptLoad.length && isExistingUser) {
                const deptVal = $prefDeptLoad.val();
                const deptEmpty = !deptVal || (Array.isArray(deptVal) ? deptVal.length === 0 : String(deptVal).trim() === '');
                if (deptEmpty) {
                    const deptGroup = $('#pu-dept-combobox').closest('.form-group');
                    if (!deptGroup.find('.help-block-new').length) {
                        deptGroup.addClass('has-warning-new');
                        $('#pu-dept-combobox').after('<span class="help-block-new" role="note">Nouveau champ obligatoire : veuillez sélectionner au moins un département.</span>');
                        $prefDeptLoad.one('change', function() {
                            const v = $(this).val();
                            if (v && (Array.isArray(v) ? v.length > 0 : v.trim() !== '')) {
                                deptGroup.removeClass('has-warning-new');
                                deptGroup.find('.help-block-new').remove();
                                removeMissingId('warn-preferredDepartments');
                            }
                        });
                    }
                }
            }

            // Type de projet vide : avertissement individuel + bandeau
            const $useTypeField = $('#project_owner_useType');
            if ($useTypeField.length && isExistingUser) {
                const utVal = $useTypeField.val();
                const utEmpty = !utVal || String(utVal).trim() === '';
                if (utEmpty) {
                    const utGroup = $useTypeField.closest('.form-group');
                    if (!utGroup.find('.help-block-new').length) {
                        utGroup.addClass('has-warning-new');
                        const $utChosen = $useTypeField.next('.chzn-container');
                        ($utChosen.length ? $utChosen : $useTypeField).after('<span class="help-block-new" role="note">Nouveau champ obligatoire : veuillez sélectionner un type de projet.</span>');
                    }
                    $useTypeField.one('change', function() {
                        const v = $(this).val();
                        if (v && String(v).trim() !== '') {
                            utGroup.removeClass('has-warning-new');
                            utGroup.find('.help-block-new').remove();
                            removeMissingId('warn-useType');
                            buildBanner(getMissingIds());
                        }
                    });
                }
            }

            // Type de projet archivé : message sous le select + retrait du bandeau après changement
            if ($useTypeField.length && $('#js-form-space').attr('data-use-type-archived') === '1') {
                const utGroup = $useTypeField.closest('.form-group');
                if (!utGroup.find('.help-block-new').length) {
                    utGroup.addClass('has-warning-new');
                    const $utChosen2 = $useTypeField.next('.chzn-container');
                    ($utChosen2.length ? $utChosen2 : $useTypeField).after('<span class="help-block-new" role="note">Ce type de projet n\'est plus proposé : sélectionnez une autre ligne dans la liste (sans la mention « archivé »), puis enregistrez.</span>');
                }
                $useTypeField.on('change', function() {
                    utGroup.removeClass('has-warning-new');
                    utGroup.find('.help-block-new').remove();
                    removeMissingId('warn-useType-archived');
                    removeMissingId('warn-useType');
                    $('#js-form-space').attr('data-use-type-archived', '0');
                    buildBanner(getMissingIds());
                });
            }

            // Le select useType est stylé/masqué par chosen:
            // on retire le required natif HTML5 pour éviter l'erreur focus navigateur.
            $('#project_owner_useType').prop('required', false).removeAttr('required');

            // Champ departements (multi-select ergonomique avec suppression par croix)
            const $preferredDepartments = $('#project_owner_preferredDepartments');
            if ($preferredDepartments.length && $.fn.chosen) {
                // Le champ natif est masqué par le combobox custom:
                // on retire le "required" HTML pour éviter l'erreur navigateur
                // "ne peut recevoir le focus". La contrainte serveur reste active.
                $preferredDepartments.prop('required', false).removeAttr('required');

                if ($preferredDepartments.hasClass('chzn-done')) {
                    $preferredDepartments.trigger('chosen:updated');
                } else {
                    $preferredDepartments.chosen({
                        width: '100%',
                        no_results_text: 'Aucun departement trouve pour : ',
                        placeholder_text_multiple: 'Selectionnez un ou plusieurs departements'
                    });
                }
            }

            // Combobox / Autocomplete départements (code 75 ou nom Paris)
            if ($preferredDepartments.length) {
                const $deptInput = $('#preferred-departments-combobox-input');
                const $deptResults = $('#preferred-departments-combobox-results');
                const $deptTags = $('#preferred-departments-combobox-tags');

                const allDepts = $preferredDepartments.find('option').map(function() {
                    return {
                        value: String($(this).val()),
                        text: String($(this).text()).trim()
                    };
                }).get();

                function escapeHtml(str) {
                    return $('<div>').text(str).html();
                }

                function getSelectedValues() {
                    const v = $preferredDepartments.val();
                    if (!v) return [];
                    return Array.isArray(v) ? v.map(String) : [String(v)];
                }

                // Etat interne (source de vérité), pour éviter les états transitoires de chosen
                let selectedCodes = getSelectedValues();

                function syncSelectedToSelect() {
                    const selectedSet = new Set(selectedCodes.map(String));
                    $preferredDepartments.find('option').each(function() {
                        const optValue = String($(this).val());
                        $(this).prop('selected', selectedSet.has(optValue));
                    });
                    $preferredDepartments.trigger('change');
                    if ($preferredDepartments.hasClass('chzn-done')) {
                        $preferredDepartments.trigger('chosen:updated');
                    }
                }

                function renderTags() {
                    const selected = selectedCodes;
                    $deptTags.empty();

                    selected.forEach(function(code) {
                        const found = allDepts.find(d => d.value === code);
                        const label = found ? found.text : code;
                        $deptTags.append(
                            '<span class="pu-dept-tag" data-value="' + escapeHtml(String(code)) + '">' +
                                escapeHtml(label) +
                                '<button type="button" class="pu-dept-tag-remove" aria-label="Retirer">×</button>' +
                            '</span>'
                        );
                    });
                }

                function hideResults() {
                    // Rendre le comportement déterministe (stoppe eventuellement des animations/callbacks)
                    $deptResults.stop(true, true).hide();
                    $deptResults.empty();
                }

                function showResults(depts, query) {
                    $deptResults.empty();
                    if (!depts.length) {
                        $deptResults.append('<div class="pu-dept-result" style="cursor:default;color:#888;">Aucun résultat pour "' + escapeHtml(query) + '"</div>');
                        $deptResults.show();
                        return;
                    }

                    depts.forEach(function(d) {
                        const selectedNow = selectedCodes.map(String).includes(String(d.value));
                        const label = d.text;
                        $deptResults.append(
                            '<div class="pu-dept-result" role="option" data-value="' + escapeHtml(String(d.value)) + '"' + (selectedNow ? ' style="opacity:0.6;"' : '') + '>' +
                            escapeHtml(label) +
                            '</div>'
                        );
                    });
                    $deptResults.show();
                }

                // Mettre à jour les tags quand la valeur change (ex: Tout effacer)
                $preferredDepartments.on('change', function() {
                    // On resynchronise l'état interne si besoin (ex: restauration session)
                    selectedCodes = getSelectedValues();
                    renderTags();

                    // Validation en temps réel
                    const deptOuterGroup = $('#pu-dept-combobox').closest('.form-group');
                    $('#pu-dept-combobox').nextAll('.js-help-block').remove();
                    const val = $preferredDepartments.val();
                    const isEmpty = !val || (Array.isArray(val) ? val.length === 0 : String(val).trim() === '');
                    if (isEmpty) {
                        deptOuterGroup.addClass('has-error');
                        $('#pu-dept-combobox').after('<span class="help-block js-help-block" role="alert" aria-live="polite">Veuillez sélectionner au moins un département.</span>');
                    } else {
                        deptOuterGroup.removeClass('has-error');
                        $preferredDepartments.closest('.form-group').removeClass('has-error');
                    }
                });

                // Validation au blur de l'input (l'utilisateur quitte le champ sans rien sélectionner)
                $deptInput.on('blur', function() {
                    const deptOuterGroup = $('#pu-dept-combobox').closest('.form-group');
                    const val = $preferredDepartments.val();
                    const isEmpty = !val || (Array.isArray(val) ? val.length === 0 : String(val).trim() === '');
                    if (isEmpty) {
                        $('#pu-dept-combobox').nextAll('.js-help-block').remove();
                        deptOuterGroup.addClass('has-error');
                        $('#pu-dept-combobox').after('<span class="help-block js-help-block" role="alert" aria-live="polite">Veuillez sélectionner au moins un département.</span>');
                    }
                });

                // Filtrage temps réel
                $deptInput.on('input', function() {
                    const q = String($(this).val() || '').trim();
                    const qLower = q.toLowerCase();
                    if (!qLower) {
                        hideResults();
                        return;
                    }

                    const matches = allDepts
                        .filter(d => d.value.toLowerCase().includes(qLower) || d.text.toLowerCase().includes(qLower))
                        .slice(0, 12);

                    showResults(matches, q);
                });

                // Sélection: on ajoute sans permettre la suppression individuelle
                $(document).on('click', '#preferred-departments-combobox-results .pu-dept-result', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    // On cache immédiatement les résultats
                    hideResults();

                    const value = String($(this).data('value') || '');
                    if (!value) return;

                    if (!selectedCodes.map(String).includes(value)) {
                        selectedCodes.push(value);
                    }
                    syncSelectedToSelect();
                    renderTags();
                    // Après ajout, on vide la saisie pour éviter un rendu "bizarre" et
                    // permettre d'enchaîner avec une nouvelle recherche.
                    $deptInput.val('');
                    hideResults();
                    $deptInput.focus();
                    return false;
                });

                // Suppression individuelle via la croix sur le tag
                $(document).on('click', '#preferred-departments-combobox-tags .pu-dept-tag-remove', function(e) {
                    e.preventDefault();
                    e.stopPropagation();

                    const $tag = $(this).closest('.pu-dept-tag');
                    const code = String($tag.data('value') || '');
                    if (!code) return false;

                    selectedCodes = selectedCodes.map(String).filter(v => v !== String(code));
                    syncSelectedToSelect();
                    renderTags();
                    // On referme la liste si elle est ouverte
                    hideResults();
                    $deptInput.focus();
                    return false;
                });

                // Fermer la liste si clic hors du champ
                $(document).on('click', function(e) {
                    if (!$(e.target).closest('#pu-dept-combobox').length) {
                        hideResults();
                    }
                });

                renderTags();
            }

            // Suppression de document via POST (évite les formulaires imbriqués qui cassent le formulaire principal)
            $(document).on('click', '.js-profile-remove-doc', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var $link = $(this);
                if (!confirm($link.data('confirm'))) return false;
                var $form = $('<form>').attr({ method: 'POST', action: $link.data('url') });
                $form.append($('<input>').attr({ type: 'hidden', name: 'token', value: $link.data('token') }));
                $form.append($('<input>').attr({ type: 'hidden', name: 'anchor', value: $link.data('anchor') }));
                $('body').append($form);
                $form.submit();
                return false;
            });

            // Restaurer les données du formulaire si elles existent
            const savedFormData = sessionStorage.getItem('profileFormData');
            if (savedFormData) {
                const formData = JSON.parse(savedFormData);
                
                // Restaurer chaque champ
                Object.keys(formData).forEach(function(fieldName) {
                    const $field = $('[name="' + fieldName + '"]');
                    if ($field.length > 0) {
                        const value = formData[fieldName];
                        const type = $field.attr('type');
                        
                        if (type === 'checkbox' || type === 'radio') {
                            $field.prop('checked', value);
                        } else {
                            $field.val(value);
                        }
                    }
                });
                
                // Supprimer les données sauvegardées
                sessionStorage.removeItem('profileFormData');
            }
            // Gestion de la navigation par anchor
            function handleAnchorNavigation() {
                const hash = window.location.hash;
                if (hash) {
                    // Retirer le # du hash
                    const sectionId = hash.substring(1);
                    
                    // Vérifier s'il y a des messages de succès (après soumission du formulaire)
                    const hasSuccessMessage = $('.alert-success').length > 0;
                    
                    // Si c'est après une soumission réussie, faire défiler vers le message de succès
                    if (hasSuccessMessage) {
                        // Faire défiler vers le message de succès en haut de page
                        setTimeout(function() {
                            $('html, body').animate({
                                scrollTop: 0
                            }, 500);
                        }, 100);
                        
                        // Nettoyer l'URL pour éviter la confusion
                        if (history.replaceState) {
                            history.replaceState(null, null, window.location.pathname);
                        }
                        return;
                    }
                    
                    // Trouver l'indicateur correspondant et l'activer
                    const $indicator = $('a.indicator[href="#' + sectionId + '"]');
                    if ($indicator.length > 0) {
                        // Désactiver tous les indicateurs
                        $('a.indicator').removeClass('active');
                        // Activer l'indicateur correspondant
                        $indicator.addClass('active');
                        
                        // Faire défiler vers la section
                        setTimeout(function() {
                            $('#' + sectionId)[0].scrollIntoView({ behavior: 'smooth' });
                        }, 100);
                    }
                }
            }
            
            // Appeler la fonction au chargement
            handleAnchorNavigation();
            
            // Fonction de validation des champs
            function handleFieldValidation(field) {
                const $field = $(field);
                const formGroup = $field.closest('.form-group, .social-group, .civility-group');
                const value = $field.val();
                const isRequired = $field.prop('required') || $field.closest('.required').length > 0 || $field.attr('id') === 'project_owner_useType';
                const isValueEmpty = (val) => {
                    if (val === null || val === undefined) return true;
                    if (Array.isArray(val)) return val.length === 0;
                    if (typeof val === 'string') return val.trim() === '';
                    // fallback: convertir en string
                    return String(val).trim() === '';
                };
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.js-help-block').remove();
                
                if (isRequired && isValueEmpty(value)) {
                    // Champ requis mais vide - afficher l'erreur
                    let errorMessage = 'Ce champ est requis';
                    if ($field.attr('id') === 'project_owner_useType') {
                        errorMessage = 'Veuillez sélectionner un type d\'usage';
                    }
                    formGroup.removeClass('has-error').addClass('has-error');
                    formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">' + errorMessage + '</span>');
                } else if (isRequired && !isValueEmpty(value)) {
                    // Champ requis et rempli - pas d'erreur, pas de vert
                    formGroup.removeClass('has-error');
                } else if (!isRequired) {
                    // Pour les champs non requis, pas de validation visuelle
                    formGroup.removeClass('has-error');
                }
            }
            
            // Validation en temps réel sur blur et change (sauf radio buttons et file inputs)
            $('input, select, textarea').not('input[type="radio"]').not('input[type="file"]').on('blur change', function() {
                const $field = $(this);

                // Champs numériques (type="number") avec valeur invalide (ex: "vv") :
                // validity.badInput = true, .val() = "" → le handler spécifique gère,
                // on laisse passer pour éviter le faux "Ce champ est requis".
                if (this.validity && this.validity.badInput) {
                    return;
                }
                
                // Validation spéciale pour les champs texte avec emojis
                if ($field.is('textarea') && /description/i.test($field.attr('name') || '')) {
                    const formGroup = $field.closest('.form-group');
                    const value = $field.val();
                    const isRequired = $field.prop('required') || $field.closest('.required').length > 0;
                    
                    // Supprimer les anciens messages d'erreur
                    formGroup.find('.js-help-block').remove();
                    formGroup.removeClass('has-error');
                    
                    if (!value || value.trim() === '') {
                        // Champ vide
                        if (isRequired) {
                            formGroup.append('<span class="help-block js-help-block" role="alert">Ce champ est requis</span>');
                            formGroup.addClass('has-error');
                            $field.attr('aria-invalid', 'true');
                        } else {
                            $field.attr('aria-invalid', 'false');
                        }
                    } else {
                        // Champ rempli - vérifier les emojis
                        const emojiRegex = /[\u{1F600}-\u{1F64F}]|[\u{1F300}-\u{1F5FF}]|[\u{1F680}-\u{1F6FF}]|[\u{1F1E0}-\u{1F1FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/u;
                        const hasEmojis = emojiRegex.test(value);
                        
                        if (hasEmojis) {
                            formGroup.append('<span class="help-block js-help-block" role="alert">Le texte ne doit pas contenir d\'emojis</span>');
                            formGroup.addClass('has-error');
                            $field.attr('aria-invalid', 'true');
                        } else {
                            // Texte valide
                            $field.attr('aria-invalid', 'false');
                        }
                    }
                } else {
                    // Validation standard pour les autres champs
                    handleFieldValidation(this);
                }
            });
            
            // Validation spéciale pour les champs téléphone
            $('input[type="tel"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.js-help-block').remove();
                
                if (value !== '') {
                    // Regex pour validation téléphone français et international
                    const phoneRegex = /^(\+33\s?[1-9](\s?\d{2}){4}|0[1-9](\s?\d{2}){4})$/;
                    
                    if (!phoneRegex.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le format du téléphone n\'est pas valide. Utilisez le format français (01 23 45 67 89) ou international (+33 1 23 45 67 89).</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    // Vérifier si c'est le téléphone personnel (obligatoire)
                    if ($field.attr('name') && $field.attr('name').includes('phone') && !$field.attr('name').includes('company')) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le téléphone est obligatoire.</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                }
            });
            
            // Validation spéciale pour le champ SIRET
            $('input[name*="siret"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.js-help-block').remove();
                
                if (value !== '') {
                    // Vérifier le format SIRET avec ou sans espaces
                    if (!/^(\d{3}\s?){4}\d{2}$/.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le SIRET doit contenir exactement 14 chiffres. Format accepté : 123 456 789 01234</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    formGroup.removeClass('has-error');
                }
            });
            
            // Validation spéciale pour le champ code postal
            $('input[name*="zipcode"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.js-help-block').remove();
                
                if (value !== '') {
                    // Vérifier que c'est exactement 5 chiffres
                    if (!/^\d{5}$/.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le code postal doit contenir exactement 5 chiffres.</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    // Champ obligatoire mais vide
                    formGroup.addClass('has-error');
                    formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le code postal est obligatoire.</span>');
                }
            });
            
            // Validation spéciale pour le téléphone mobile (obligatoire)
            $('input[name*="companyMobile"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.js-help-block').remove();
                
                if (value !== '') {
                    // Regex pour validation téléphone français et international
                    const phoneRegex = /^(\+33\s?[1-9](\s?\d{2}){4}|0[1-9](\s?\d{2}){4})$/;
                    
                    if (!phoneRegex.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le format du téléphone n\'est pas valide. Utilisez le format français (06 12 34 56 78) ou international (+33 6 12 34 56 78).</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    formGroup.addClass('has-error');
                    formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le téléphone mobile est obligatoire.</span>');
                }
            });
            
            // Validation spéciale pour les champs URL (réseaux sociaux + site web)
            // Couvre : facebookUrl, twitterUrl, linkedinUrl, instagramUrl, googleUrl, otherUrl, companySite
            $('input').filter(function() {
                const name = $(this).attr('name') || '';
                return /Url\]|companySite\]/.test(name);
            }).on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();

                formGroup.find('.js-help-block').remove();

                if (value !== '' && !/^https?:\/\/.+/.test(value)) {
                    formGroup.addClass('has-error');
                    formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Seuls les liens commençant par http:// ou https:// sont acceptés.</span>');
                } else {
                    formGroup.removeClass('has-error');
                }
            });

            // Validation des champs numériques : surface, effectif, budget
            // Note : ces champs sont type="number" → .val() retourne "" si valeur non numérique.
            //        On utilise validity.badInput pour détecter ce cas.
            const numericFieldsConfig = [
                { selector: 'wishedSize',       label: 'La surface',             unit: 'm²' },
                { selector: 'companyEffective', label: 'Le nombre de personnes', unit: ''   },
                { selector: 'monthlyBudgetMax', label: 'Le budget',              unit: '€'  }
            ];
            numericFieldsConfig.forEach(function(cfg) {
                $('input[name*="' + cfg.selector + '"]').on('blur change', function() {
                    const $field = $(this);
                    const formGroup = $field.closest('.form-group');
                    const value = $field.val().trim();
                    const badInput = this.validity && this.validity.badInput;

                    // Champ vraiment vide (sans badInput) : on n'intervient pas.
                    // Le handler générique a déjà affiché "Ce champ est requis" si nécessaire.
                    if (value === '' && !badInput) {
                        return;
                    }

                    // À partir d'ici on a quelque chose à valider → on prend la main.
                    formGroup.find('.js-help-block').remove();
                    formGroup.removeClass('has-error');

                    // badInput = true  : type="number" avec texte invalide ("vv"),
                    //                    .val() retourne "" → détecté via badInput
                    // badInput = false : type="text" (NumberType Symfony), .val() retourne "vv"
                    //                    → vérifié avec regex
                    if (badInput || !/^\d+$/.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">' +
                            cfg.label + ' doit être un nombre entier' +
                            (cfg.unit ? ' en ' + cfg.unit : '') + ' (ex : 50).</span>');
                    } else if (parseInt(value, 10) < 0) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">' +
                            cfg.label + ' doit être un nombre positif.</span>');
                    }
                });
            });

            // Validation spéciale pour les groupes de radio (civilité)
            $('input[name*="civility"]').on('change', function() {
                const civilityGroup = $('.civility-group');
                civilityGroup.find('.js-help-block').remove();
                
                if ($('input[name*="civility"]:checked').length > 0) {
                    civilityGroup.removeClass('has-error');
                } else {
                    civilityGroup.addClass('has-error');
                    civilityGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Veuillez sélectionner votre civilité</span>');
                }
            });

            // Valider tous les champs requis au submit pour donner un retour
            // immédiat et éviter de perdre les fichiers déjà sélectionnés.
            $('form.has-crosses').on('submit', function(e) {
                // Le submit est bloqué UNIQUEMENT pour les champs dont une valeur vide
                // empêcherait la sauvegarde serveur (NotBlank projectHolder) sans que
                // l'utilisateur puisse facilement voir pourquoi.
                // Pour les autres champs vides, on affiche les erreurs JS (feedback visuel)
                // mais on laisse le serveur valider → sauvegarde partielle possible.
                let blockSubmit = false;

                // 1. Civilité — feedback visuel uniquement (pas bloquant)
                const $civilityGroup = $('.civility-group');
                $civilityGroup.find('.js-help-block').remove();
                if ($('input[name*="civility"]:checked').length === 0) {
                    $civilityGroup.addClass('has-error');
                    $civilityGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Veuillez sélectionner votre civilité</span>');
                } else {
                    $civilityGroup.removeClass('has-error');
                }

                // 2. Champs requis — feedback visuel uniquement (pas bloquant)
                $(this).find('input[required]:not([type="tel"]):not([type="radio"]):not([type="file"]), select[required], textarea[required]').each(function() {
                    handleFieldValidation(this);
                });

                // 2b. Fichiers requis — BLOQUANT
                // Si on laisse soumettre au serveur avec un fichier manquant, le serveur
                // recharge la page et le navigateur vide tous les inputs file (sécurité
                // navigateur), ce qui fait "disparaître" le fichier déjà sélectionné.
                $('.required-files input[type="file"]').each(function() {
                    const $input = $(this);
                    const fileInfo = $input.closest('.file-infos');
                    fileInfo.find('.js-help-block').remove();
                    if (!this.files || this.files.length === 0) {
                        fileInfo.addClass('has-error');
                        fileInfo.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Ce fichier est requis</span>');
                        blockSubmit = true;
                    } else {
                        fileInfo.removeClass('has-error');
                    }
                });

                // 2c. Téléphones requis et format valide — BLOQUANT
                // Si on laisse soumettre avec un téléphone vide ou invalide, le serveur va rejeter
                // la soumission et rafraîchir la page, faisant perdre les fichiers joints.
                const phoneRegex = /^(\+33\s?[1-9](\s?\d{2}){4}|0[1-9](\s?\d{2}){4})$/;
                
                // Téléphone personnel
                const $personalPhone = $('input[name*="[phone]"]');
                if ($personalPhone.length) {
                    const formGroup = $personalPhone.closest('.form-group');
                    formGroup.find('.js-help-block').remove();
                    const value = $personalPhone.val().trim();
                    if (value === '') {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le téléphone est obligatoire.</span>');
                        blockSubmit = true;
                    } else if (!phoneRegex.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le format du téléphone n\'est pas valide. Utilisez le format français (01 23 45 67 89) ou international (+33 1 23 45 67 89).</span>');
                        blockSubmit = true;
                    } else {
                        formGroup.removeClass('has-error');
                    }
                }

                // Téléphone mobile structure
                const $companyMobile = $('input[name*="companyMobile"]');
                if ($companyMobile.length) {
                    const formGroup = $companyMobile.closest('.form-group');
                    formGroup.find('.js-help-block').remove();
                    const value = $companyMobile.val().trim();
                    if (value === '') {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le téléphone mobile est obligatoire.</span>');
                        blockSubmit = true;
                    } else if (!phoneRegex.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le format du téléphone n\'est pas valide. Utilisez le format français (06 12 34 56 78) ou international (+33 6 12 34 56 78).</span>');
                        blockSubmit = true;
                    } else {
                        formGroup.removeClass('has-error');
                    }
                }

                // 3. Emojis dans les descriptions — BLOQUANT
                const emojiRegex = /[\u{1F600}-\u{1F64F}]|[\u{1F300}-\u{1F5FF}]|[\u{1F680}-\u{1F6FF}]|[\u{1F1E0}-\u{1F1FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/u;
                $(this).find('textarea').each(function() {
                    const $ta = $(this);
                    if (!/description/i.test($ta.attr('name') || '')) return;
                    const formGroup = $ta.closest('.form-group');
                    formGroup.find('.js-help-block').remove();
                    formGroup.removeClass('has-error');
                    if (emojiRegex.test($ta.val())) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le texte ne doit pas contenir d\'emojis</span>');
                        blockSubmit = true;
                    }
                });

                // 4. companyStatus vide — BLOQUANT
                //    Le placeholder a remplacé l'ancienne valeur par défaut "SA".
                //    Sans ce blocage JS, le serveur rejetterait silencieusement la sauvegarde.
                const $companyStatus = $('select[name*="companyStatus"]');
                if ($companyStatus.length) {
                    handleFieldValidation($companyStatus.get(0));
                    const csVal = $companyStatus.val();
                    if (csVal === null || csVal === undefined || String(csVal).trim() === '') {
                        blockSubmit = true;
                    }
                }

                // 5. useType vide — BLOQUANT (évite de perdre les fichiers joints)
                const $useType = $('#project_owner_useType');
                if ($useType.length) {
                    handleFieldValidation($useType.get(0));
                    const utVal = $useType.val();
                    if (utVal === null || utVal === undefined || String(utVal).trim() === '') {
                        blockSubmit = true;
                    }
                }

                // 6. preferredDepartments vide — BLOQUANT (même raison)
                const $prefDept = $('#project_owner_preferredDepartments');
                if ($prefDept.length) {
                    const deptOuterGroup = $('#pu-dept-combobox').closest('.form-group');
                    $('#pu-dept-combobox').nextAll('.js-help-block').remove();
                    const deptVal = $prefDept.val();
                    const deptEmpty = !deptVal || (Array.isArray(deptVal) ? deptVal.length === 0 : String(deptVal).trim() === '');
                    if (deptEmpty) {
                        deptOuterGroup.addClass('has-error');
                        $('#pu-dept-combobox').after('<span class="help-block js-help-block" role="alert" aria-live="polite">Veuillez sélectionner au moins un département.</span>');
                        blockSubmit = true;
                    } else {
                        deptOuterGroup.removeClass('has-error');
                        $prefDept.closest('.form-group').removeClass('has-error');
                    }
                }

                // Si l'un des champs requis ou validés présente une erreur visuelle, on bloque la soumission.
                if ($(this).find('.form-group.has-error, .file-infos.has-error').length > 0) {
                    blockSubmit = true;
                }

                // 7. Bloquer et scroller vers la première erreur si nécessaire
                if (blockSubmit) {
                    e.preventDefault();
                    const firstErrorEl = document.querySelector('.form-group.has-error .help-block, .file-infos.has-error .help-block');
                    if (firstErrorEl) {
                        const scrollTarget = firstErrorEl.closest('.form-group') || firstErrorEl.closest('.file-infos');
                        if (scrollTarget) {
                            scrollTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    }
                }
            });
            
            // Gestion spéciale pour les fichiers
            $('.file-infos input[type="file"]').on('change', function() {
                const fileInfo = $(this).closest('.file-infos');
                const file = this.files[0];
                
                // Supprimer les anciens messages d'erreur
                fileInfo.find('.js-help-block').remove();
                
                if (file) {
                    // Vérifier la taille du fichier (10Mo max)
                    if (file.size > 10 * 1024 * 1024) {
                        fileInfo.addClass('has-error');
                        fileInfo.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Le fichier est trop volumineux (maximum 10Mo)</span>');
                    } else {
                        fileInfo.removeClass('has-error');
                        
                        // Mettre à jour la coche verte immédiatement après sélection d'un fichier valide
                        updateDocumentCheckmark($(this));
                    }
                } else {
                    // Si aucun fichier sélectionné et que le champ est requis
                    if ($(this).closest('.required-files').length > 0) {
                        fileInfo.addClass('has-error');
                        fileInfo.append('<span class="help-block js-help-block" role="alert" aria-live="polite">Ce fichier est requis</span>');
                        
                        // Retirer la coche verte si le fichier est supprimé
                        removeDocumentCheckmark($(this));
                    } else {
                        fileInfo.removeClass('has-error');
                    }
                }
            });

            function updateDocumentCheckmark($input) {
                const $container = $input.closest('.required-files');
                const $checkmark = $container.find('.fa-times');
                if ($checkmark.length > 0) {
                    $checkmark.removeClass('fa-times').addClass('fa-check');
                }
            }

            function removeDocumentCheckmark($input) {
                const $container = $input.closest('.required-files');
                const $checkmark = $container.find('.fa-check');
                if ($checkmark.length > 0) {
                    $checkmark.removeClass('fa-check').addClass('fa-times');
                }
            }
        });
    </script>
{% endblock %}
