{% extends "base.html.twig" %}

{% block prebody %}{% endblock %}

{% block body %}
{% embed 'Partials/_auth_split_layout.html.twig' %}
{% block auth_body %}
<div class="login-page">
    <div class="colorBox-content registration" style="background: rgba(255, 255, 255, 0.9); padding: 30px; border-radius: 8px;">
        <img class="icon" src="{{ asset('/bundles/app/images/lock_icon.png') }}" style="width: 48px; margin-bottom: 20px;" />

        <h4 style="font-size: 24px; font-weight: 600; margin-bottom: 20px; color: #333;">Connexion</h4>

        <div id="cboxContent white">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error_sign' or type == 'error' or type == 'danger' or type == 'error_msg' ? 'danger' : (type == 'success_msg' or type == 'success' ? 'success' : 'info') }} alert-error" style="margin-top: 10px; margin-bottom: 15px; padding: 10px; border-radius: 4px;">
                        {{ message|raw }}
                    </div>
                {% endfor %}
            {% endfor %}
            <form action="{{ path("app_login") }}" method="post">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" />

                <div class="form-group" style="margin-bottom: 15px;">
                    <div class="input-group">
                        <span class="input-group-addon"><img src="{{ asset('/bundles/app/images/user_login.png') }}" alt="user" class="closed" /></span>
                        <input type="text" placeholder="Votre email" id="username" name="_username" value="{{ last_username|default('') }}" required="required" class="form-control" style="height: 45px; font-size: 16px;"/>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 15px;">
                    <div class="input-group">
                        <span class="input-group-addon"><img src="{{ asset('/bundles/app/images/lock_login.png') }}" alt="mdp" class="closed"/></span>
                        <input type="password" placeholder="Votre mot de passe" id="password" name="_password" required="required" class="form-control" style="height: 45px; font-size: 16px;"/>
                    </div>
                </div>

                {% if error %}
                    <div class="alert alert-danger alert-error" style="margin-top: 10px; margin-bottom: 10px; padding: 10px; border-radius: 4px;">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <input type="submit" id="_submit" name="_submit" value="Je me connecte" class="btn btn-line-login"/>
            </form>

            <div class="text-left" style="margin-top: 15px;">
                <p class="forgotten"><a href="{{ path('fos_user_resetting_request') }}" style="color: #666; text-decoration: underline;">Identifiant ou mot de passe oublié ?</a></p>
            </div>
            <hr class="black" style="border-top: 1px solid #eee; margin: 20px 0;"/>
            <div class="text-left">
                <p>
                    <span class="connex" style="color: #666;">Vous n'avez pas de compte Plateau Urbain ?</span>
                    <br />
                    <i class="fa-solid fa-arrow-right"></i> <a class="connex" href="{{ path('fos_user_registration_register') }}" style="color: #333; font-weight: bold; text-decoration: underline;">Inscription</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
{% endembed %}
{% endblock %}
