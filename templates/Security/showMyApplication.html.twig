{% extends "base.html.twig" %}

{# {% block breadcrumb_items %}
  <li><a href="{{ path('security_profil') }}">Mon compte</a></li>
  <li><a href="{{ path('my_applications_list') }}">Mes candidatures</a></span></li>
  <li><span>Ma candidature pour : {{application.space.name}}</span></li>
{% endblock %} #}

{% block stylesheets %}
  {{ parent() }}

  <link rel="stylesheet" href="{{ asset('bundles/app/css/print.css') }}" type="text/css" media="print" />
{% endblock %}

{% block body %}
<div class="white"> 
        <div class="container"> 
<div class="application-header left">
 <div class="row">
    <div class="col-sm-6">
        <h3>{{ application.name }}</h3>
        <h6>{{ application.projectHolder.company }}</h6>
         {% if not application.isDraft %}
        <p>Candidature envoyée le {{ application.created|date('d/m/Y') }}</p>
      {% endif %}
    </div> 
    <div class="col-sm-6 application-status right">
      {% include 'Application/partials/_status_label.html.twig' %}
    </div>
</div>
</div>

{% set space = application.space %}
<div class="application-space space-card item show-app {{ space.listingCardClass }}" id="space-card">
  <div class="item">
    <div class="row row-flex">
      <div class="col-xs-12 col-md-4 ">
        <div class="image">
          <div class="overlay">
             {% if application.space.isClosed %}
                          <div class="clos"><p> Appel à candidature cloturé</p></div>
                        {% else %}
                          <div class="encours"><p> Appel à candidature en cours</p></div>
                        {% endif %}
          </div>
          <div class="image-wrapper">
            <img class="img-responsive" src="{% if space.pics.0 is not null %}{{ vich_uploader_asset(application.space.pics.0, 'file') }}{% endif %}" alt="" />
          </div>
          <div class="availability-overlay">
            <span class="availability-text">Durée du projet : {{ space.availability }}</span>
          </div>
        </div>
      </div>

      <div class="col-xs-12 col-md-8 box-info">
        <div class="info">
          <div class="row">
            <div class="col-sm-7">
                <p class="ville">{{ space.displayCity|default(space.city) }}{% if not space.isMultiLocation and space.depCode %} ({{ space.depCode }}){% endif %}</p>
                <h5>{{ application.space.name }}</h5>               
            </div>
           {#  <div class="col-sm-5 right">
               <a href="{{ path('space_show', {'id': space.id}) }}"class="red"><span class="sub-arrow"><i class="fa fa-square"></i></span>Voir l'annonce</a>              
            </div> #}
    </div>

    <div class="row">
            <ul>
              <li>{{ space.type }}</li>
              <li>
                {% if space.priceText %}
                  {{ space.priceText }}
                {% else %}
                  À partir de {{ space.price * 12 }} € / m<sup>2</sup> / an
                {% endif %}
              </li>
              {% if not space.isMultiLocation and (space.nbSpaces or space.minSpace or space.maxSpace) %}
              <li>
                <strong>{{ space.nbSpaces }}</strong> espace(s) de {{ space.minSpace }} m<sup>2</sup> à {{ space.maxSpace }} m<sup>2</sup>
              </li>
              {% endif %}
                <li>Bailleur: {{ application.space.owner.company }}</li>
              </ul>
             </div>
     </div> 

     <div class="info-candidature">
                     <div class="row">
                       <div class="col-sm-6">
                            <div class="calendar"></div>
                            <div class="apply-date">
                            {% if space.isMultiLocation %}
                            <p class="apply-date-p">Candidatures</p>
                            <p class="apply-date-b">Ouvertes</p>
                            {% else %}
                            <p class="apply-date-p">Date limite de candidature</p>
                            <p class="apply-date-b">
                  {{ space.limitAvailability | localizeddate("long", "none", "fr") }} à {{ space.limitAvailability|date('H') }}h{{ space.limitAvailability|date('i') }}
                  </p>
                            {% endif %}
                      </div>
      </div>

              <div class="col-sm-6 right">
                  <a href="{{ path('space_show', { 'id': space.id }) }}" class="btn btn-line-19 btn-grey"><span>Voir fiche projet</span></a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
</div>
        

<div class="print-flow">
<div class="row print-sections">
  <div class="col-sm-12 print-order-contact">
    <div class="box-information">    
      <div class="box-content">
         <h4 class="box-title">
        Contact
      </h4>
        <table>
          <tbody>
            <tr><th>Candidat</th><td>{{ application.projectHolder.fullName }}</td></tr>
            {% if application.projectHolder.birthday %}
              <tr><th>Date de naissance</th><td>{{ application.projectHolder.birthday|date('d/m/Y') }}</td></tr>
            {% endif %}
            {% if application.projectHolder.phone %}
              <tr><th>Téléphone</th><td>{{ application.projectHolder.phone }}</td></tr>
            {% endif %}
            {% if application.projectHolder.email %}
              <tr><th>Email</th><td>{{ application.projectHolder.email }}</td></tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

<div class="col-sm-12 print-order-structure">
    <div class="box-information">    
      <div class="box-content">
          <h4 class="box-title">
        Structure
      </h4>
        <table>
          <tbody>
            {% if application.projectHolder.company %}
              <tr><th>Nom de la structure</th><td>{{ application.projectHolder.company }}</td></tr>
            {% endif %}
            {% if application.projectHolder.companyStatus %}
              <tr><th>Statut</th><td>{{ application.projectHolder.companyStatus }}</td></tr>
            {% endif %}
            {% if application.projectHolder.useType %}
              <tr><th>Secteur d'activité</th><td>{{ application.projectHolder.useType }}</td></tr>
            {% endif %}
            {% if application.projectHolder.isSubjectToVat is not null %}
              <tr><th>Assujetti à la TVA</th><td>{{ application.projectHolder.isSubjectToVat ? 'Oui' : 'Non' }}</td></tr>
            {% endif %}
            <tr>
              <th>Date de création</th>
              <td>
                {% if application.projectHolder.companyCreationDate %}
                    {{ application.projectHolder.companyCreationDate|date("d/m/Y") }}
                {% endif %}
              </td>
            </tr>
            {% if application.projectHolder.companyCreationDate %}
              {# ligne conservée ci-dessus #}
            {% endif %}
            {% if application.projectHolder.siret %}
              <tr><th>SIRET</th><td>{{ application.projectHolder.siret }}</td></tr>
            {% endif %}
            {% if application.projectHolder.city %}
              <tr><th>Ville</th><td>{{ application.projectHolder.city }}</td></tr>
            {% endif %}
            {% if application.projectHolder.zipcode %}
              <tr><th>Code postal</th><td>{{ application.projectHolder.zipcode }}</td></tr>
            {% endif %}
            {% if application.projectHolder.address %}
              <tr><th>Adresse</th><td>{{ application.projectHolder.address }}</td></tr>
            {% endif %}
            {% if application.projectHolder.companyPhone %}
              <tr><th>Téléphone fixe</th><td>{{ application.projectHolder.companyPhone }}</td></tr>
            {% endif %}
            {% if application.projectHolder.companyMobile %}
              <tr><th>Téléphone mobile</th><td>{{ application.projectHolder.companyMobile }}</td></tr>
            {% endif %}
            {% if application.projectHolder.companyDescription %}
              <tr><th>Présentation</th><td>{{ application.projectHolder.companyDescription|nl2br }}</td></tr>
            {% endif %}
            {% if application.projectHolder.companyEffective %}
              <tr><th>Nombre de personnes dans la structure</th><td>{{ application.projectHolder.companyEffective }}</td></tr>
            {% endif %}
            {% if application.projectHolder.companyStructures %}
              <tr><th>Structure(s) d'accompagnement</th><td>{{ application.projectHolder.companyStructures|nl2br }}</td></tr>
            {% endif %}
            {% if application.projectHolder.isPuShareholder is not null %}
              <tr><th>Déjà sociétaire Plateau Urbain</th><td>{{ application.projectHolder.isPuShareholder ? 'Oui' : 'Non' }}</td></tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

{% set hasAnySocialOrWeb = application.projectHolder.companySite or application.projectHolder.companyBlog or application.projectHolder.facebookUrl or application.projectHolder.twitterUrl or application.projectHolder.instagramUrl or application.projectHolder.linkedinUrl or application.projectHolder.youtubeUrl or application.projectHolder.tiktokUrl or application.projectHolder.googleUrl or application.projectHolder.otherUrl %}
{% if hasAnySocialOrWeb %}
  <div class="col-sm-12 print-order-social">
    <div class="box-information">     
      <div class="box-content">
         <h4 class="box-title">
        Site internet et réseaux sociaux
      </h4>
        <table>
          <tbody>
            {% if application.projectHolder.companySite %}
              <tr>
                <th><i class="fa fa-globe fa-lg" style="margin-right: 5px;"></i> Site web</th>
                <td>{% set _site = application.projectHolder.companySite|safe_href %}{% if _site %}<a href="{{ _site }}" target="_blank" rel="noopener noreferrer">{{ application.projectHolder.companySite|length > 30 ? application.projectHolder.companySite|slice(0, 30) ~ '...' : application.projectHolder.companySite }}</a>{% else %}{{ application.projectHolder.companySite }}{% endif %}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.companyBlog %}
              <tr>
                <th><i class="fa fa-rss fa-lg" style="margin-right: 5px;"></i> Blog</th>
                <td>{% set _blog = application.projectHolder.companyBlog|safe_href %}{% if _blog %}<a href="{{ _blog }}" target="_blank" rel="noopener noreferrer">{{ application.projectHolder.companyBlog|length > 30 ? application.projectHolder.companyBlog|slice(0, 30) ~ '...' : application.projectHolder.companyBlog }}</a>{% else %}{{ application.projectHolder.companyBlog }}{% endif %}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.facebookUrl %}
              <tr>
                <th><i class="fa-brands fa-facebook fa-lg" style="margin-right: 5px;"></i> Facebook</th>
                <td>{{ application.projectHolder.facebookUrl }}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.twitterUrl %}
              <tr>
                <th>
                  <span aria-label="X (anciennement Twitter)"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="1.33em" height="1.33em" fill="currentColor" aria-hidden="true" focusable="false" role="img" style="vertical-align: middle; margin-right: 4px;"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z"/></svg></span> Twitter
                </th>
                <td>{{ application.projectHolder.twitterUrl }}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.instagramUrl %}
              <tr>
                <th><i class="fa-brands fa-instagram fa-lg" style="margin-right: 5px;"></i> Instagram</th>
                <td>{{ application.projectHolder.instagramUrl }}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.linkedinUrl %}
              <tr>
                <th><i class="fa-brands fa-linkedin fa-lg" style="margin-right: 5px;"></i> LinkedIn</th>
                <td>{{ application.projectHolder.linkedinUrl }}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.youtubeUrl %}
              <tr>
                <th><i class="fa-brands fa-youtube fa-lg" style="margin-right: 5px;"></i> YouTube</th>
                <td>{{ application.projectHolder.youtubeUrl }}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.tiktokUrl %}
              <tr>
                <th><i class="fa-brands fa-tiktok fa-lg" style="margin-right: 5px;"></i> TikTok</th>
                <td>{{ application.projectHolder.tiktokUrl }}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.googleUrl %}
              <tr>
                <th>
                  <span aria-label="Bluesky"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 530" width="1.33em" height="1.33em" fill="currentColor" aria-hidden="true" focusable="false" role="img" style="vertical-align: middle; margin-right: 4px;"><path d="m135.72 44.03c66.5 49.92 138.02 151.14 164.28 205.46 26.26-54.32 97.78-155.54 164.28-205.46 47.98-36.021 125.72-63.892 125.72 24.795 0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3797-3.6904-10.832-3.7077-7.8964-0.0174-2.9357-1.1937 0.51669-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4491-163.25-81.433-5.9562-21.282-16.111-152.36-16.111-170.07 0-88.687 77.742-60.816 125.72-24.795z"/></svg></span> Bluesky
                </th>
                <td>{{ application.projectHolder.googleUrl }}</td>
              </tr>
            {% endif %}
            {% if application.projectHolder.otherUrl %}
              <tr>
                <th><i class="fa fa-link fa-lg" style="margin-right: 5px;"></i> Autre URL</th>
                <td>{{ application.projectHolder.otherUrl }}</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{% endif %}
</div>

<div class="row print-sections">
  <div class="col-sm-12 print-order-project">
    <div class="box-information allow-break">
      <div class="box-content">
      <h4 class="box-title">
        Projet pour cet espace
      </h4>
        <table>
          <tbody>
            <tr><th>Nom du projet</th><td>{{ application.name }}</td></tr>
            {% if application.category %}
              <tr><th>Type d'usage</th><td>{{ application.category }}</td></tr>
            {% endif %}
            {% if application.projectHolder.preferredDepartmentsLabels|length %}
              <tr><th>Départements souhaités</th><td>{{ application.projectHolder.preferredDepartmentsLabels|join(', ') }}</td></tr>
            {% endif %}
            {% if application.companyStatus %}
              <tr><th>Statut juridique</th><td>{{ application.companyStatus }}</td></tr>
            {% endif %}
            {% if application.wishedSize %}
              <tr><th>Surface souhaitée</th><td>{{ application.wishedSize }} m<sup>2</sup></td></tr>
            {% endif %}
            {% set _lengthValue = application.lengthOccupation ?: application.projectHolder.usageDuration %}
            {% set _lengthType = application.lengthTypeOccupation ?: application.projectHolder.lengthTypeOccupation %}
            <tr>
              <th>Durée d'occupation</th>
              <td>
                {% if _lengthValue %}
                  {{ _lengthValue }}{% if _lengthType %} {{ _lengthType }}{% endif %}
                {% else %}
                  —
                {% endif %}
              </td>
            </tr>
            {% if application.projectHolder.monthlyBudgetMax %}
              <tr><th>Budget mensuel total maximum</th><td>{{ application.projectHolder.monthlyBudgetMax }} €</td></tr>
            {% endif %}
            {% if application.startOccupation %}
              <tr><th>Date d'entrée souhaitée</th><td>{{ application.startOccupation|date('d/m/Y') }}</td></tr>
            {% endif %}
            {% if application.description %}
              <tr><th>Présentation du projet</th><td>{{ application.description|nl2br }}</td></tr>
            {% endif %}
            {% if application.localUsageDescription %}
              <tr><th>Quel sera l'usage du local ?</th><td>{{ application.localUsageDescription|nl2br }}</td></tr>
            {% endif %}
            {% include 'Application/Partials/_location_preferences.html.twig' with { application: application } %}
            <tr><th>Ouvert(e) à un projet collectif</th><td>{{ application.openToGlobalProject ? 'Oui' : 'Non' }}</td></tr>
            {% if application.contribution %}
              <tr><th>Quelles idées avez-vous pour participer au projet collectif ?</th><td>{{ application.contribution|nl2br }}</td></tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  

  <div class="col-sm-12 print-order-docs">
    <div class="box-information">
      <div class="box-content">
      <h4 class="box-title">
        Documents disponibles
      </h4>
        <div class="files">

  
            <div class="file-infos">
              <div style="display:inline-block; width:80%">Pièce d'identité</div>
              <div style="display:inline-block" class="pull-right actions" >
                {% if application.projectHolder.hasDocuments('id') %}
                {% set file =  application.projectHolder.getDocumentsType('id')[0] %}
                <a target="_blank" href="{{ asset(vich_uploader_asset(file, 'file')) }}" class="btn btn-download"><i class="fa fa-eye fa-lg"></i></a>
                {% endif %}
              </div>
            </div>
          
            <div class="file-infos">
              <div style="display:inline-block; width:80%">Document justifiant la création de la structure</div>
              <div style="display:inline-block" class="pull-right actions" >
                {% if application.projectHolder.hasDocuments('kbis') %}
                {% set file =  application.projectHolder.getDocumentsType('kbis')[0] %}
                <a target="_blank" href="{{ asset(vich_uploader_asset(file, 'file')) }}" class="btn btn-download"><i class="fa fa-eye fa-lg"></i></a>
                {% endif %}
              </div>
            </div>
         

          {% for doc in application.projectHolder.getDocumentsType('') %}
              <div class="file-infos">
                <div style="display:inline-block; width:80%">{{doc.fileName | slice(14, 100)}}</div>
                <div style="display:inline-block" class="pull-right actions" >
                    <a target="_blank" href="{{ asset(vich_uploader_asset(doc, 'file')) }}" class="btn btn-download"><i class="fa fa-eye fa-lg"></i></a>
                </div>
              </div>
          {% endfor %}

          {% for doc in application.files %}
              <div class="file-infos">
                <div style="display:inline-block; width:80%">{{doc.fileName | slice(14, 100)}}</div>
                <div style="display:inline-block" class="pull-right actions" >
                    <a target="_blank" href="{{ asset(vich_uploader_asset(doc, 'file')) }}" class="btn btn-download"><i class="fa fa-eye fa-lg"></i></a>
                </div>
              </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
</div>

<div class="row application_buttons">
  <div class="save-recap center">
    {% if application.isDraft and not application.space.isClosed %}
      <a href="{{ path('space_apply', {'space': application.space.id}) }}" class="btn btn-line-form-end">
        <i class="fa fa-pencil fa-lg"></i>
        Continuer ma candidature
      </a>
    {% endif %}
    <a href="javascript:print();" class="btn btn-line-form-end">
      <i class="fa-solid fa-print fa-lg"></i>
      Imprimer ma candidature
    </a>
  </div>
</div>


<div class="pagination-wrapper">
    <ul class="pagination">

        <li>
            {% if prevApplication %}
                <a href="{{ path('my_application_show', { 'id': prevApplication.id }) }}" aria-label="Prev" title="Candidature précédente" data-toggle="tooltip">
                    <span aria-hidden="true"></span>
                </a>
            {% else %}
                <span aria-label="Previous">
                    <span aria-hidden="true"></span>
                </span>
            {% endif %}
        </li>

        <li>
            {% if nextApplication %}
            <a href="{{ path('my_application_show', { 'id': nextApplication.id }) }}" aria-label="Next"  title="Candidature suivante" data-toggle="tooltip">
                <span aria-hidden="true"></span>
            </a>
            {% else %}
                <span aria-label="Next">
                    <span aria-hidden="true"></span>
                </span>
            {% endif %}
        </li>

    </ul>
</div>

</div>
</div>

{% endblock %}
