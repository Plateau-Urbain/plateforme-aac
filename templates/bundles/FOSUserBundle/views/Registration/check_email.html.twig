{% extends "bundles/FOSUserBundle/views/layout.html.twig" %}

{% block fos_user_content %}
{% embed 'Partials/_auth_split_layout.html.twig' %}
{% block auth_body %}
<div class="login-page">
    <div class="colorBox-content registration" style="background: rgba(255, 255, 255, 0.9); padding: 30px; border-radius: 8px;">
        <img class="icon" src="{{ asset('/bundles/app/images/lock_icon.png') }}" style="width: 48px; margin-bottom: 20px;" />
        <h4 style="font-size: 24px; font-weight: 600; margin-bottom: 20px; color: #333;">Activation de compte</h4>
        {% if email %}
            <p>Un e-mail d’activation vient d’être envoyé à <strong>{{ email }}</strong>.</p>
        {% else %}
            <p>Un e-mail d’activation vient d’être envoyé à votre adresse.</p>
        {% endif %}
        <p>Ouvrez le lien reçu pour activer votre compte, puis connectez-vous. Pensez à vérifier vos spams.</p>
        <p style="margin-top: 20px;">
            <a class="btn btn-line-login" href="{{ path('app_login') }}">Retour à la connexion</a>
        </p>
    </div>
</div>
{% endblock %}
{% endembed %}
{% endblock fos_user_content %}
