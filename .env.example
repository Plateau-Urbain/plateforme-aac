# Copier ce fichier vers .env.local et adapter les valeurs.
#   cp .env.example .env.local
#
# Ne jamais committer .env.local (ignoré par Git).
# Le fichier .env versionné contient des valeurs par défaut sûres pour le dev.

###> symfony/framework-bundle ###
APP_ENV=dev
# Générer une clé : php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=change_me_generate_a_random_secret
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Adapter utilisateur, mot de passe, nom de base et serverVersion à votre installation.
DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/plateau_urbain?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/plateau_urbain?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
# Développement sans envoi réel :
MAILER_DSN=null://null
# Production (Brevo) :
# MAILER_DSN=brevo+api://YOUR_BREVO_API_KEY@default
# MAILER_DSN=brevo+smtp://USERNAME:PASSWORD@default
###< symfony/mailer ###

###> app/mail-and-routing ###
MAIL_CONFIRMATION_FROM=noreply@example.com
MAIL_CONFIRMATION_TO=admin@example.com
APP_BASE_URL=localhost
###< app/mail-and-routing ###

###> symfony/framework-bundle (production) ###
# Uniquement en APP_ENV=prod, derrière un reverse proxy (nginx, etc.) :
# TRUSTED_PROXIES=127.0.0.1,10.0.0.1
###< symfony/framework-bundle (production) ###
